---
import { getHeadingTag } from "../../lib/ui-logic/presentation";
import type { HeadingLevel, Cta } from "../../lib/ui-logic/types";
import type { HeroCoverImage } from "../../lib/ui-logic/hero-cover-image";
import { isHeroCoverResponsive } from "../../lib/ui-logic/hero-cover-image";
import ButtonGroup from "./ButtonGroup.astro";

type Props = {
  /** Omit when the page supplies the primary heading elsewhere (for example a `ContentSection` above this block). */
  heading?: string;
  body?: string;
  eyebrow?: string;
  /** Full-bleed cover: string URL or responsive WebP + JPEG (`HeroSection` parallax targets inner `img`). */
  backgroundImage?: HeroCoverImage;
  headingLevel?: HeadingLevel | "h4";
  /** Optional; omit or pass `[]` when the band uses only the default slot (for example testimonials). */
  ctas?: Cta[];
  /** Use when `heading` is omitted so the band has an accessible name (for example "Boka Art Yoga"). */
  ariaLabel?: string;
  /** Override loading behavior. Default "lazy"; set "eager" for above-fold cover bands. */
  loading?: "lazy" | "eager";
  /** Hint to the browser. Use "high" for above-fold LCP candidates. */
  fetchpriority?: "high" | "low" | "auto";
};

const {
  heading,
  body,
  eyebrow,
  backgroundImage,
  headingLevel = "h1",
  ctas = [],
  ariaLabel,
  loading = "lazy",
  fetchpriority,
} = Astro.props as Props;
const HeadingTag = getHeadingTag(headingLevel, "h1");
const hasImage = Boolean(backgroundImage);
const sectionAria = !heading && ariaLabel ? ariaLabel : undefined;
const hasDefaultSlot = Astro.slots.has("default");
const coverResponsive = isHeroCoverResponsive(backgroundImage);
---

<section
  class={`component-hero ${hasImage ? "is-cover" : "is-solid"}`}
  aria-label={sectionAria}
>
  {
    hasImage ? (
      <>
        {coverResponsive ? (
          <picture class="component-hero-cover-picture">
            <source
              type="image/webp"
              srcset={`${backgroundImage.webp640} 640w, ${backgroundImage.webp960} 960w`}
              sizes="100vw"
            />
            <img
              src={backgroundImage.jpeg960}
              alt=""
              class="component-hero-media"
              width="960"
              height="640"
              loading={loading}
              decoding="async"
              fetchpriority={fetchpriority}
            />
          </picture>
        ) : (
          <img
            src={backgroundImage as string}
            alt=""
            class="component-hero-media"
            loading={loading}
            decoding="async"
            fetchpriority={fetchpriority}
          />
        )}
        <div class="component-hero-cover-overlay" aria-hidden="true" />
      </>
    ) : null
  }
  <div class="component-hero-content">
    {eyebrow ? <p class="component-eyebrow">{eyebrow}</p> : null}
    {heading ? <HeadingTag>{heading}</HeadingTag> : null}
    {body ? <p class="component-lead">{body}</p> : null}
    {
      hasDefaultSlot ? (
        <div class="component-hero-slot">
          <slot />
        </div>
      ) : null
    }
    {ctas.length > 0 ? <ButtonGroup buttons={ctas} /> : null}
  </div>
</section>
{
  hasImage ? (
    <script>
      import "../../client-scripts/hero-cover-parallax.ts";
    </script>
  ) : null
}
