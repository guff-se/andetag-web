---
import { getHeadingTag } from "../../lib/components/presentation";
import type { HeadingLevel, Cta } from "../../lib/components/types";
import ButtonGroup from "./ButtonGroup.astro";

type Props = {
  heading: string;
  body?: string;
  eyebrow?: string;
  backgroundImage?: string;
  backgroundStyle?: "inline" | "cover";
  headingLevel?: HeadingLevel | "h4";
  ctas: Cta[];
};

const {
  heading,
  body,
  eyebrow,
  backgroundImage,
  backgroundStyle = "inline",
  headingLevel = "h1",
  ctas,
} = Astro.props as Props;
const HeadingTag = getHeadingTag(headingLevel, "h1");
---

<section class={`component-hero ${backgroundStyle === "cover" ? "is-cover" : ""}`.trim()}>
  {backgroundImage ? <img src={backgroundImage} alt="" class="component-hero-media" loading="lazy" /> : null}
  {backgroundStyle === "cover" ? <div class="component-hero-cover-overlay" aria-hidden="true"></div> : null}
  <div class="component-hero-content">
    {eyebrow ? <p class="component-eyebrow">{eyebrow}</p> : null}
    <HeadingTag>{heading}</HeadingTag>
    {body ? <p class="component-lead">{body}</p> : null}
    <ButtonGroup buttons={ctas} />
  </div>
</section>
