---
/**
 * Grid of artwork cards. Filter classes are applied to the `[data-artwork-grid]`
 * container by `client-scripts/artworks-filter.ts`; CSS handles visibility.
 */
import type { Artwork } from "../../lib/content/artworks";
import ArtworkCard from "./ArtworkCard.astro";

type Props = {
  artworks: readonly Artwork[];
  language: "sv" | "en";
  /** First card on the page can be eagerly loaded for LCP. */
  eagerFirst?: boolean;
  /** Suffix used for unique grid id (e.g. "originals", "gems"). */
  gridId: string;
};

const { artworks, language, eagerFirst = false, gridId } = Astro.props as Props;
---

<div
  class="artwork-grid"
  data-artwork-grid
  data-grid-id={gridId}
  data-filter-status="all"
  data-filter-format="all"
>
  {artworks.map((artwork, i) => (
    <ArtworkCard artwork={artwork} language={language} eager={eagerFirst && i === 0} />
  ))}
</div>
