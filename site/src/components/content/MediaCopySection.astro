---
import ResponsiveInlinePicture from "../ui/ResponsiveInlinePicture.astro";
import type { BodyPictureSources } from "../../lib/content/stockholm-body-responsive-images";
import { getHeadingTag } from "../../lib/ui-logic/presentation";
import type { HeadingLevel } from "../../lib/ui-logic/types";

/**
 * Section-level component pairing a figure with copy in a 2-column grid at
 * tablet+ widths and stacking on mobile. The component owns the grid, the
 * figure CSS, and the vertical alignment so page bodies never wrap a
 * `ContentSection` (or any other top-level page block) in an ad-hoc grid div
 * — that pattern produces empty cells when image height ≠ copy height and
 * orphans the section's outer margins inside a cell that doesn't expect them.
 *
 * The copy half is a `<slot/>` so callers can place any content there:
 * paragraphs (`set:html` of trusted HTML), an `InfoFrame`, an
 * `AccordionSection`, a `ButtonGroup`, etc. Headings render at the top of the
 * copy half via the `heading` + `headingLevel` props (`<h2>` by default), so
 * a section's H2 always sits inside the same flow as its body.
 *
 * Image-aspect rule (see `skills/images/SKILL.md` §L5): pair portraits with
 * dense copy (long body / structured block) and landscapes with short copy.
 * The component does not crop; it lets the figure render at its natural
 * aspect and centers the shorter sibling vertically. A bad aspect pairing
 * still looks ragged — the rule lives in the skill, not the component.
 *
 * Props:
 * - `heading?` / `headingLevel?` — render an H2/H3 (etc.) at the top of the
 *   copy half. Omit for slot-only callers.
 * - `bodyHtml?` — convenience for trusted HTML before the slot. Use the slot
 *   for anything that needs Astro components (InfoFrame, AccordionSection).
 * - `imageSources` / `imageAlt` / `imageWidth` / `imageHeight` — same
 *   contract as `ResponsiveInlinePicture`.
 * - `mediaSide` — `"start"` (image left, copy right) or `"end"` (copy left,
 *   image right; default).
 * - `mediaWidth` — `"third"` (image 1/3, copy 2/3; default) or `"half"`
 *   (1/1 split). Mobile: always single column, image after copy.
 * - `mediaSizes` — optional sizes attribute override for the image.
 */
type Props = {
  imageSources: BodyPictureSources;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  mediaSide?: "start" | "end";
  mediaWidth?: "third" | "half";
  heading?: string;
  headingLevel?: HeadingLevel;
  bodyHtml?: string;
  mediaSizes?: string;
  /** Optional class hook for one-off page tweaks; the component still owns layout. */
  class?: string;
};

const {
  imageSources,
  imageAlt,
  imageWidth,
  imageHeight,
  mediaSide = "end",
  mediaWidth = "third",
  heading,
  headingLevel = "h2",
  bodyHtml,
  mediaSizes,
  class: extraClass,
} = Astro.props as Props;

const HeadingTag = getHeadingTag(headingLevel, "h2");

const sectionClass = [
  "media-copy",
  `media-copy--media-${mediaSide}`,
  `media-copy--media-${mediaWidth}`,
  extraClass ?? "",
]
  .filter(Boolean)
  .join(" ");

const defaultSizes = mediaWidth === "third"
  ? "(min-width: 1024px) 22rem, (min-width: 768px) 28vw, 92vw"
  : "(min-width: 1024px) 30rem, (min-width: 768px) 44vw, 92vw";

const sizes = mediaSizes ?? defaultSizes;
---

<section class={sectionClass}>
  <div class="media-copy__prose">
    {heading ? <HeadingTag class="media-copy__heading">{heading}</HeadingTag> : null}
    {bodyHtml ? <div class="media-copy__body" set:html={bodyHtml} /> : null}
    <slot />
  </div>
  <figure class="media-copy__media">
    <ResponsiveInlinePicture
      sources={imageSources}
      alt={imageAlt}
      width={imageWidth}
      height={imageHeight}
      sizes={sizes}
    />
  </figure>
</section>
