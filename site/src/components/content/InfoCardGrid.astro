---
import StyledLink from "../ui/StyledLink.astro";

type Card = {
  title: string;
  body: string;
  cta?: {
    label: string;
    href: string;
  };
};

type Props = {
  cards: Card[];
};

const { cards } = Astro.props as Props;
---

<section class="info-card-grid">
  {cards.map((card) => (
    <article class="info-card">
      <h3>{card.title}</h3>
      <p>{card.body}</p>
      {card.cta ? <StyledLink {...card.cta} styleVariant="content" /> : null}
    </article>
  ))}
</section>
