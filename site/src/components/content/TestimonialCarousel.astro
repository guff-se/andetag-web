---
import type { BodyPictureSources } from "../../lib/content/stockholm-body-responsive-images";
import { testimonialCarouselDefaultBg } from "../../lib/content/stockholm-body-responsive-images";
import ButtonGroup from "./ButtonGroup.astro";
import type { Cta } from "../../lib/ui-logic/types";

type TestimonialItem = {
  quote: string;
  author?: string;
};

/** Optional aggregate strip below quotes; background image spans carousel + aggregate. */
type TestimonialAggregate = {
  eyebrow: string;
  score: string;
  scoreCaption: string;
  meta: string;
  linkHref: string;
  linkLabel: string;
  /** Optional; use when visible `linkLabel` omits the destination name (for example Tripadvisor wordmark nearby). */
  linkAriaLabel?: string;
  regionAriaLabel?: string;
  /** When false, hide self-hosted Tripadvisor dots + wordmark and show Unicode stars in the score row instead. */
  showTripAdvisorBrand?: boolean;
};

const tripadvisorDotsSrc = "/assets/tripadvisor/tripadvisor-5dots.png";
const tripadvisorLogoSrc = "/assets/tripadvisor/tripadvisor-logo.svg";

type Props = {
  items: TestimonialItem[];
  /** CSS `url()` string, or responsive WebP + JPEG (default: optimized testimonial band still). */
  backgroundImage?: string | BodyPictureSources;
  /** Descriptive alt for responsive background `<img>` (page language). */
  backgroundImageAlt?: string;
  autoplayMs?: number;
  aggregate?: TestimonialAggregate;
  prevLabel?: string;
  nextLabel?: string;
  cta?: Cta;
};

const {
  items,
  backgroundImage: backgroundImageProp = testimonialCarouselDefaultBg,
  backgroundImageAlt = "",
  autoplayMs = 6000,
  aggregate,
  prevLabel = "Previous testimonial",
  nextLabel = "Next testimonial",
  cta,
} = Astro.props as Props;

const useResponsiveBg =
  typeof backgroundImageProp === "object" &&
  backgroundImageProp !== null &&
  "jpeg960" in backgroundImageProp;
const legacyBgUrl = typeof backgroundImageProp === "string" ? backgroundImageProp : null;
const responsiveBg = useResponsiveBg ? (backgroundImageProp as BodyPictureSources) : null;

const regionLabel = aggregate?.regionAriaLabel ?? "Sammanfattning av omdömen";
const showTripAdvisorBrand = aggregate ? aggregate.showTripAdvisorBrand !== false : false;
---

<section
  class="testimonial-block"
  style={legacyBgUrl ? `--testimonial-background-image: url('${legacyBgUrl}')` : undefined}
>
  <div
    class:list={["testimonial-block__bg", useResponsiveBg && "testimonial-block__bg--picture"]}
    aria-hidden="true"
  >
    {
      useResponsiveBg && responsiveBg ? (
        <picture>
          <source
            type="image/webp"
            srcset={`${responsiveBg.webp640} 640w, ${responsiveBg.webp960} 960w`}
            sizes="100vw"
          />
          <img
            src={responsiveBg.jpeg960}
            alt={backgroundImageAlt}
            class="testimonial-block__bg-img"
            loading="lazy"
            decoding="async"
          />
        </picture>
      ) : null
    }
  </div>
  <div class="testimonial-block__overlay" aria-hidden="true"></div>
  <div class="testimonial-block__carousel js-testimonial-carousel" data-autoplay-ms={autoplayMs}>
    <div class="testimonial-carousel-viewport" aria-live="polite">
      {items.map((item, index) => (
        <blockquote
          class={`testimonial-slide${index === 0 ? " is-active" : ""}`}
          data-slide-index={index}
          aria-hidden={index === 0 ? "false" : "true"}
        >
          <p>{item.quote}</p>
          {item.author ? <cite>{item.author}</cite> : null}
        </blockquote>
      ))}
    </div>
    {
      items.length > 1 ? (
        <>
          <button class="testimonial-nav testimonial-nav-prev" type="button" aria-label={prevLabel}>
            <span aria-hidden="true">‹</span>
          </button>
          <button class="testimonial-nav testimonial-nav-next" type="button" aria-label={nextLabel}>
            <span aria-hidden="true">›</span>
          </button>
        </>
      ) : null
    }
  </div>
  {
    aggregate ? (
      <div class="testimonial-block__aggregate">
        <div class="testimonial-block__aggregate-inner" role="region" aria-label={regionLabel}>
          <p class="testimonial-block__aggregate-eyebrow">{aggregate.eyebrow}</p>
          {
            showTripAdvisorBrand ? (
              <div class="testimonial-block__aggregate-brand">
                <img
                  class="testimonial-block__aggregate-dots"
                  src={tripadvisorDotsSrc}
                  alt=""
                  width="512"
                  height="96"
                  loading="lazy"
                  decoding="async"
                />
                <img
                  class="testimonial-block__aggregate-logo"
                  src={tripadvisorLogoSrc}
                  alt="Tripadvisor"
                  width="561"
                  height="86"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ) : null
          }
          <div class="testimonial-block__aggregate-score-row">
            <p class="testimonial-block__aggregate-score">
              {aggregate.score}
              <span>{aggregate.scoreCaption}</span>
            </p>
            {
              !showTripAdvisorBrand ? (
                <div class="testimonial-block__aggregate-stars" aria-hidden="true">
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                </div>
              ) : null
            }
          </div>
          <p class="testimonial-block__aggregate-meta">{aggregate.meta}</p>
          <a
            class="testimonial-block__aggregate-link"
            href={aggregate.linkHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={aggregate.linkAriaLabel}
          >
            {aggregate.linkLabel}
          </a>
        </div>
      </div>
    ) : null
  }
  {cta ? (
    <div class="testimonial-block__cta">
      <ButtonGroup buttons={[cta]} />
    </div>
  ) : null}
</section>

<script>
  import "../../client-scripts/testimonial-carousel-init.ts";
</script>
