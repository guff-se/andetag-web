---
import { getHeadingTag } from "../../lib/ui-logic/presentation";
import type { HeadingLevel } from "../../lib/ui-logic/types";

type Props = {
  heading?: string;
  headingHtml?: string;
  headingLevel?: HeadingLevel | "h4";
  markdown: string;
  align?: "left" | "center";
};

const { heading, headingHtml, headingLevel = "h2", markdown, align = "left" } = Astro.props as Props;
const HeadingTag = getHeadingTag(headingLevel, "h2");
---

<section class={`content-section align-${align}`}>
  {headingHtml ? <HeadingTag set:html={headingHtml} /> : heading ? <HeadingTag>{heading}</HeadingTag> : null}
  <div class="content-section-body" set:html={markdown} />
</section>
