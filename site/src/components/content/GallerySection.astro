---
type GalleryImage = {
  src: string;
  alt: string;
  caption?: string;
  fullSrc?: string;
};

type Props = {
  images: GalleryImage[];
  mobileMode: "carousel" | "grid";
  galleryId?: string;
  /** `aria-label` on the gallery region when `mobileMode` is `carousel`. */
  carouselAriaLabel?: string;
  /** Localized prev/next labels and slide counts for `mobileMode` `carousel`. */
  galleryNavLocale?: "sv" | "en";
};

const {
  images,
  mobileMode,
  galleryId = "phase3-gallery",
  carouselAriaLabel = "Image gallery",
  galleryNavLocale = "en",
} = Astro.props as Props;

const navPrevLabel = galleryNavLocale === "sv" ? "Föregående bild" : "Previous image";
const navNextLabel = galleryNavLocale === "sv" ? "Nästa bild" : "Next image";

const slideCountLabel = (index: number) =>
  galleryNavLocale === "sv"
    ? `${index + 1} av ${images.length}`
    : `${index + 1} of ${images.length}`;

const sectionClass =
  mobileMode === "carousel"
    ? "gallery-section mobile-carousel js-gallery-mobile-carousel"
    : "gallery-section mobile-grid";
---

<section
  class={sectionClass}
  data-gallery-id={galleryId}
  role="region"
  aria-label={carouselAriaLabel}
>
  {
    images.map((image, index) => (
      <figure
        class="gallery-tile"
        role={mobileMode === "carousel" ? "group" : undefined}
        aria-roledescription={mobileMode === "carousel" ? "slide" : undefined}
        aria-label={mobileMode === "carousel" ? slideCountLabel(index) : undefined}
      >
        <a
          href={image.fullSrc ?? image.src}
          class="gallery-lightbox-link js-gallery-lightbox"
          data-gallery={galleryId}
          aria-label={image.alt}
        >
          <img src={image.src} alt={image.alt} loading="lazy" />
          <span class="gallery-hover-overlay" aria-hidden="true" />
        </a>
        {image.caption ? <figcaption>{image.caption}</figcaption> : null}
      </figure>
    ))
  }
  {
    mobileMode === "carousel" && images.length > 1 ? (
      <>
        <button
          type="button"
          class="gallery-carousel-btn gallery-carousel-btn-prev"
          aria-label={navPrevLabel}
        >
          <span aria-hidden="true">‹</span>
        </button>
        <button
          type="button"
          class="gallery-carousel-btn gallery-carousel-btn-next"
          aria-label={navNextLabel}
        >
          <span aria-hidden="true">›</span>
        </button>
      </>
    ) : null
  }
</section>

<script>
  import $ from "jquery";

  const ensureLightbox = () => {
    if (document.getElementById("gallery-lightbox-overlay")) {
      return;
    }

    const overlay = document.createElement("div");
    overlay.id = "gallery-lightbox-overlay";
    overlay.className = "gallery-lightbox-overlay";
    overlay.innerHTML = `
      <button type="button" class="gallery-lightbox-close" aria-label="Close image">&times;</button>
      <img class="gallery-lightbox-image" alt="" />
    `;
    document.body.appendChild(overlay);
  };

  ensureLightbox();

  const $overlay = $("#gallery-lightbox-overlay");
  const $image = $overlay.find(".gallery-lightbox-image");

  $(document).on("click", ".js-gallery-lightbox", (event) => {
    event.preventDefault();
    const target = event.currentTarget;
    if (!(target instanceof HTMLAnchorElement)) return;
    const imageUrl = target.getAttribute("href");
    const imageAlt = target.getAttribute("aria-label") ?? "";
    if (!imageUrl) return;
    $image.attr("src", imageUrl);
    $image.attr("alt", imageAlt);
    $overlay.addClass("is-open");
    document.body.classList.add("lightbox-open");
  });

  $(document).on("click", ".gallery-lightbox-close, #gallery-lightbox-overlay", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (
      target.classList.contains("gallery-lightbox-overlay") ||
      target.classList.contains("gallery-lightbox-close")
    ) {
      $overlay.removeClass("is-open");
      document.body.classList.remove("lightbox-open");
    }
  });

  $(document).on("keydown", (event) => {
    if (event.key === "Escape") {
      $overlay.removeClass("is-open");
      document.body.classList.remove("lightbox-open");
    }
  });
</script>

<script>
  import "../../client-scripts/gallery-section-carousel.ts";
</script>
