---
import { getLinkClassName } from "../../lib/ui-logic/presentation";
import type { LinkStyleVariant } from "../../lib/ui-logic/types";

type Props = {
  label: string;
  href: string;
  styleVariant: LinkStyleVariant;
  external?: boolean;
  className?: string;
};

const { label, href, styleVariant, external = false, className = "" } = Astro.props as Props;
const rel = external ? "noreferrer noopener" : undefined;
const target = external ? "_blank" : undefined;
---

<a
  href={href}
  class={`shared-link ${getLinkClassName(styleVariant)} ${className}`.trim()}
  rel={rel}
  target={target}
>
  {label}
</a>
