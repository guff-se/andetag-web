---
type Props = {
  title: string;
  src: string;
  fallbackText: string;
  unavailable?: boolean;
  /** When true, no border, fill, or padding (flush map tile). */
  unframed?: boolean;
};

const { title, src, fallbackText, unavailable = false, unframed = false } = Astro.props as Props;
const shellClass = ["embed-shell", unframed ? "embed-shell--unframed" : ""].filter(Boolean).join(" ");
---

<section class={shellClass}>
  {unavailable ? (
    <p class="embed-fallback" role="status">{fallbackText}</p>
  ) : (
    <iframe title={title} src={src} loading="lazy" class="embed-frame" />
  )}
</section>
