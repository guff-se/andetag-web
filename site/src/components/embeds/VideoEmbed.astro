---
type Props = {
  title: string;
  src: string;
  fallbackText: string;
  unavailable?: boolean;
  /** Self-hosted poster WebP path (root-relative). Falls back to JPEG sibling. */
  posterWebp?: string;
  /** Self-hosted poster JPEG path (root-relative). */
  posterJpeg?: string;
};

const {
  title,
  src,
  fallbackText,
  unavailable = false,
  posterWebp,
  posterJpeg,
} = Astro.props as Props;

const hasPoster = Boolean(posterWebp || posterJpeg);
---

<section class={unavailable ? "embed-shell" : "video-embed"}>
  {unavailable ? (
    <p class="embed-fallback" role="status">{fallbackText}</p>
  ) : hasPoster ? (
    <div class="video-facade" data-video-src={src} data-video-title={title}>
      <picture class="video-facade-poster">
        {posterWebp && <source type="image/webp" srcset={posterWebp} />}
        <img
          src={posterJpeg || posterWebp}
          alt={title}
          loading="lazy"
          decoding="async"
          class="video-facade-img"
        />
      </picture>
      <button type="button" class="video-facade-play" aria-label={`Play: ${title}`}>
        <svg viewBox="0 0 68 48" width="68" height="48" aria-hidden="true">
          <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24S67.94 13.05 66.52 7.74z" fill="rgba(255,255,255,0.85)"/>
          <path d="M45 24L27 14v20" fill="#0e0e10"/>
        </svg>
      </button>
    </div>
  ) : (
    <div class="embed-shell-video">
      <iframe title={title} src={src} loading="lazy" class="embed-frame embed-frame-video" />
    </div>
  )}
</section>

{hasPoster && (
  <script>
    function initVideoFacades(): void {
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const facade = target.closest(".video-facade");
        if (!facade || facade.querySelector("iframe")) return;

        const src = facade.getAttribute("data-video-src");
        const videoTitle = facade.getAttribute("data-video-title") || "";
        if (!src) return;

        const iframe = document.createElement("iframe");
        iframe.src = src + (src.includes("?") ? "&" : "?") + "autoplay=1";
        iframe.title = videoTitle;
        iframe.className = "embed-frame embed-frame-video";
        iframe.setAttribute("allow", "autoplay; fullscreen; picture-in-picture");
        iframe.setAttribute("allowfullscreen", "");

        facade.innerHTML = "";
        facade.classList.add("is-playing");
        facade.appendChild(iframe);
      });
    }
    initVideoFacades();
  </script>
)}
