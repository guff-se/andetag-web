---
/**
 * Understory booking widget. Standard page placement: `page-layout-with-aside` with this
 * component in `page-layout-with-aside__aside` (`unframed`), main column for copy beside it.
 * See `docs/phase-3-component-usage.md` → BookingEmbed.
 */
import { getHeadingTag } from "../../lib/ui-logic/presentation";
import type { HeadingLevel } from "../../lib/ui-logic/types";
import { getBookingEmbedContactHtml } from "../../lib/ui-logic/booking-embed-contact";
import { getUnderstoryWidgetConfig } from "../../lib/ui-logic/understory";

type Props = {
  companyId: string;
  language: "sv" | "en" | "de";
  anchorId?: string;
  fallbackText: string;
  unavailable?: boolean;
  /** When set, rendered as the first child inside the embed shell (before widget or fallback). */
  heading?: string;
  headingLevel?: HeadingLevel;
  /** When true, no border, fill, or padding (widget sits flush in the layout). */
  unframed?: boolean;
  /** When false, omits the standard contact line below the widget (`info@andetag.museum`). Default true. */
  showContact?: boolean;
};

const {
  companyId,
  language,
  anchorId = "book",
  fallbackText,
  unavailable = false,
  heading,
  headingLevel = "h2",
  unframed = false,
  showContact = true,
} = Astro.props as Props;
const widget = getUnderstoryWidgetConfig(companyId, language);
const contactHtml = showContact ? getBookingEmbedContactHtml(language) : null;
const HeadingTag = getHeadingTag(headingLevel, "h2");
const shellClass = ["embed-shell", "booking-embed", unframed ? "embed-shell--unframed" : ""]
  .filter(Boolean)
  .join(" ");
---

<section id={anchorId} class={shellClass}>
  {heading ? <HeadingTag class="embed-shell-heading">{heading}</HeadingTag> : null}
  {unavailable ? (
    <p class="embed-fallback" role="status">{fallbackText}</p>
  ) : (
    <>
      <script defer src={widget.scriptSrc}></script>
      <div class={widget.className} data-company-id={widget.companyId} data-language={widget.language}></div>
    </>
  )}
  {contactHtml ? (
    <div class="booking-embed-contact" set:html={contactHtml} />
  ) : null}
</section>
