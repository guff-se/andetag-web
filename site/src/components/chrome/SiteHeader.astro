---
import type { PageLayoutModel } from "../../lib/chrome/page-layout";
import { getSwedishHeroHeaderModel } from "../../lib/chrome/hero-sv";
import {
  getEnglishStockholmHeroHeaderModel,
  isEnglishStockholmSharedHeroHeader,
} from "../../lib/chrome/hero-en-stockholm";
import {
  getEnglishBerlinHeroHeaderModel,
  isEnglishBerlinSharedHeroHeader,
} from "../../lib/chrome/hero-en-berlin";
import {
  getGermanBerlinHeroHeaderModel,
  isGermanBerlinSharedHeroHeader,
} from "../../lib/chrome/hero-de-berlin";
import { BERLIN_SOCIAL_FACEBOOK_HREF, BERLIN_SOCIAL_INSTAGRAM_HREF } from "../../lib/chrome/footer-en-berlin";
import AndetagHeaderLogo from "./AndetagHeaderLogo.astro";
import { HEADER_SMALL_SV_ASSETS, HERO_SV_ASSETS } from "../../lib/chrome/assets";
import { isHeaderSmallSv } from "../../lib/chrome/header-small-sv";

const { model, currentPath } = Astro.props as { model: PageLayoutModel; currentPath: string };

const isEnHeaderSelector = model.header.id === "chrome-hdr-en-header-selector";

const desktopNav = model.navigation;
const mobileNav = model.navigationMobile;
const sharedSvHeader =
  model.header.id === "chrome-hdr-sv-stockholm-hero" || isHeaderSmallSv(model.header.id)
    ? getSwedishHeroHeaderModel(currentPath)
    : null;
const sharedEnHeader =
  isEnglishStockholmSharedHeroHeader(model.header.id) || isEnHeaderSelector
    ? getEnglishStockholmHeroHeaderModel(currentPath)
    : null;
const sharedEnBerlinHeader = isEnglishBerlinSharedHeroHeader(model.header.id)
  ? getEnglishBerlinHeroHeaderModel(currentPath)
  : null;
const sharedDeBerlinHeader = isGermanBerlinSharedHeroHeader(model.header.id)
  ? getGermanBerlinHeroHeaderModel(currentPath)
  : null;
const sharedHero = sharedSvHeader ?? sharedEnHeader ?? sharedEnBerlinHeader ?? sharedDeBerlinHeader;
const mobileLanguageAlternates =
  sharedHero?.languageFlags.filter((flag) => !flag.active) ?? [];
const isSharedBerlinHero = Boolean(sharedEnBerlinHeader ?? sharedDeBerlinHeader);
const berlinHeroCenterCopy = sharedEnBerlinHeader?.centerCopy ?? sharedDeBerlinHeader?.centerCopy;
const heroSocialInstagramHref = isSharedBerlinHero
  ? BERLIN_SOCIAL_INSTAGRAM_HREF
  : "https://www.instagram.com/andetag.museum/";
const heroSocialFacebookHref = isSharedBerlinHero
  ? BERLIN_SOCIAL_FACEBOOK_HREF
  : "https://www.facebook.com/andetag.museum";
const heroLocale = sharedSvHeader
  ? "sv"
  : sharedEnHeader || sharedEnBerlinHeader
    ? "en"
    : sharedDeBerlinHeader
      ? "de"
      : null;
const isSmallHero = Boolean(sharedHero && model.header.kind === "small");
const navAria = heroLocale === "en" ? "Menu" : heroLocale === "de" ? "Menü" : "Meny";
const navMobileAria =
  heroLocale === "en" ? "Mobile menu" : heroLocale === "de" ? "Mobiles Menü" : "Mobil meny";
const destAria = heroLocale === "en" ? "Location" : heroLocale === "de" ? "Standort" : "Plats";
const menuToggleAria =
  heroLocale === "en"
    ? "Open or close menu"
    : heroLocale === "de"
      ? "Menü öffnen oder schließen"
      : "Slå på eller av meny";
const logoHomeAria =
  heroLocale === "en" ? "Go to homepage" : heroLocale === "de" ? "Zur Startseite" : "Till startsidan";
---

{
sharedHero && (
<header
  class={`shared-hero-header${isSmallHero ? " is-small" : ""}${isEnHeaderSelector ? " shared-hero-header--selector" : ""}`}
  id="andetag-header"
>
  <div class="shared-hero-media-layer">
    {
      isSmallHero ? (
        <picture class="shared-hero-static-picture">
          <source
            media="(max-width: 767px)"
            type="image/avif"
            srcset={`${HEADER_SMALL_SV_ASSETS.mobile.avif640} 640w, ${HEADER_SMALL_SV_ASSETS.mobile.avif960} 960w`}
            sizes="100vw"
          />
          <source
            media="(max-width: 767px)"
            type="image/webp"
            srcset={`${HEADER_SMALL_SV_ASSETS.mobile.webp640} 640w, ${HEADER_SMALL_SV_ASSETS.mobile.webp960} 960w`}
            sizes="100vw"
          />
          <source
            media="(max-width: 767px)"
            type="image/jpeg"
            srcset={`${HEADER_SMALL_SV_ASSETS.mobile.jpeg640} 640w, ${HEADER_SMALL_SV_ASSETS.mobile.jpeg960} 960w`}
            sizes="100vw"
          />
          <source media="(max-width: 900px)" type="image/avif" srcset={HERO_SV_ASSETS.posterAvif960} />
          <source media="(max-width: 900px)" type="image/webp" srcset={HERO_SV_ASSETS.posterWebp960} />
          <source type="image/avif" srcset={HERO_SV_ASSETS.posterAvif1920} />
          <source type="image/webp" srcset={HERO_SV_ASSETS.posterWebp1920} />
          <img
            class="shared-hero-static-image"
            src={HERO_SV_ASSETS.posterJpeg1920}
            srcset={`${HERO_SV_ASSETS.posterJpeg960} 960w, ${HERO_SV_ASSETS.posterJpeg1920} 1920w`}
            sizes="100vw"
            width="1920"
            height="1080"
            alt=""
            aria-hidden="true"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
      ) : (
        <div class="shared-hero-video-stack">
          <picture class="shared-hero-video-poster">
            <source
              media="(max-width: 900px)"
              srcset={HERO_SV_ASSETS.posterAvif960}
              type="image/avif"
            />
            <source
              media="(max-width: 900px)"
              srcset={HERO_SV_ASSETS.posterWebp960}
              type="image/webp"
            />
            <source srcset={HERO_SV_ASSETS.posterAvif1920} type="image/avif" />
            <source srcset={HERO_SV_ASSETS.posterWebp1920} type="image/webp" />
            <img
              class="shared-hero-video-poster-img"
              src={HERO_SV_ASSETS.posterJpeg960}
              srcset={`${HERO_SV_ASSETS.posterJpeg960} 960w, ${HERO_SV_ASSETS.posterJpeg1920} 1920w`}
              sizes="100vw"
              width="1920"
              height="1080"
              alt=""
              aria-hidden="true"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
          <video
            class="shared-hero-video"
            autoplay
            muted
            playsinline
            loop
            preload="none"
            onplaying="this.classList.add('shared-hero-video--visible')"
          >
            <source src={HERO_SV_ASSETS.videoMobile} type="video/mp4" media="(max-width: 900px)" />
            <source src={HERO_SV_ASSETS.video} type="video/mp4" />
          </video>
        </div>
      )
    }
    <div class="shared-hero-overlay"></div>
  </div>

  <div class="shared-hero-content">
    <div class="shared-hero-top">
      <a class="shared-hero-logo-link andetag-logo" href={sharedHero.logoHomeHref} aria-label={logoHomeAria}>
        <AndetagHeaderLogo class="shared-hero-logo" />
      </a>

      <div class="shared-hero-top-right">
        <div class="shared-hero-socials" aria-label="Social links">
          <a href={heroSocialInstagramHref} target="_blank" rel="noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 448 512" aria-hidden="true"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
          </a>
          <a href={heroSocialFacebookHref} target="_blank" rel="noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 320 512" aria-hidden="true"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
          </a>
          <a href="https://pinterest.com/malintadaa" target="_blank" rel="noreferrer" aria-label="Pinterest">
            <svg viewBox="0 0 496 512" aria-hidden="true"><path d="M496 256c0 137-111 248-248 248-25.6 0-50.2-3.9-73.4-11.1 10.1-16.5 25.2-43.5 30.8-65 3-11.6 15.4-59 15.4-59 8.1 15.4 31.7 28.5 56.8 28.5 74.8 0 128.7-68.8 128.7-154.3 0-81.9-66.9-143.2-152.9-143.2-107 0-163.9 71.8-163.9 150.1 0 36.4 19.4 81.7 50.3 96.1 4.7 2.2 7.2 1.2 8.3-3.3.8-3.4 5-20.3 6.9-28.1.6-2.5.3-4.7-1.7-7.1-10.1-12.5-18.3-35.3-18.3-56.6 0-54.7 41.4-107.6 112-107.6 60.9 0 103.6 41.5 103.6 100.9 0 67.1-33.9 113.6-78 113.6-24.3 0-42.6-20.1-36.7-44.8 7-29.5 20.5-61.3 20.5-82.6 0-19-10.2-34.9-31.4-34.9-24.9 0-44.9 25.7-44.9 60.2 0 22 7.4 36.8 7.4 36.8s-24.5 103.8-29 123.2c-5 21.4-3 51.6-.9 71.2C65.4 450.9 0 361.1 0 256 0 119 111 8 248 8s248 111 248 248z"/></svg>
          </a>
        </div>
        <div class="shared-hero-lang-top">
          {sharedHero.topLanguages.map((language) => <a href={language.href}>{language.label}</a>)}
        </div>
        {
          !isEnHeaderSelector ? (
            <div class="shared-hero-dest-top" aria-label={destAria}>
              {
                sharedHero.destinationOptions.map((opt) => (
                  <a
                    href={opt.href}
                    class={opt.active ? "is-active" : undefined}
                    aria-current={opt.active ? "page" : undefined}
                  >
                    {opt.label}
                  </a>
                ))
              }
            </div>
          ) : null
        }
      </div>
    </div>

    {!isSmallHero && (
      <div
        class={`shared-hero-center${berlinHeroCenterCopy ? " shared-hero-center--berlin" : ""}`}
      >
        {
          berlinHeroCenterCopy ? (
            <div class="shared-hero-berlin-headings">
              <h1>
                {berlinHeroCenterCopy.titleLines[0]}
                <br />
                {berlinHeroCenterCopy.titleLines[1]}
              </h1>
              <h2>
                {berlinHeroCenterCopy.subtitleLines[0]}
                <br />
                {berlinHeroCenterCopy.subtitleLines[1]}
              </h2>
            </div>
          ) : null
        }
        {
          isEnHeaderSelector ? (
            <div
              class="shared-hero-selector-ctas"
              id="en-selector-actions"
              role="group"
              aria-label="Choose a location"
            >
              <a class="shared-hero-cta shared-hero-cta--selector-primary" href="/en/stockholm/">
                Stockholm
              </a>
              <a class="shared-hero-cta shared-hero-cta--selector-secondary" href="/en/berlin/">
                Berlin
              </a>
            </div>
          ) : (
            <a class="shared-hero-cta" href={model.header.ctaHref}>{model.header.ctaLabel}</a>
          )
        }
      </div>
    )}
  </div>

  {!isEnHeaderSelector ? (
    <>
  <div class="shared-hero-nav-shell" data-hero-nav-shell>
    <nav class="shared-hero-nav" aria-label={navAria}>
      <ul class="shared-hero-menu">
        {
          sharedHero.menuItems.map((item) => (
            <li class={`shared-hero-menu-item${item.active ? " is-active" : ""}`}>
              {item.href ? (
                <a href={item.href}>{item.label}</a>
              ) : (
                <span class="shared-hero-menu-heading">{item.label}</span>
              )}
              {item.subMenu.length > 0 ? (
                <ul class="shared-hero-submenu">
                  {item.subMenu.map((subItem) => <li><a href={subItem.href}>{subItem.label}</a></li>)}
                </ul>
              ) : null}
            </li>
          ))
        }
        {
          sharedHero.ticketItem ? (
            <li class="shared-hero-menu-item shared-hero-ticket-item">
              <a href={sharedHero.ticketItem.href}>{sharedHero.ticketItem.label}</a>
            </li>
          ) : null
        }
        <li class="shared-hero-menu-item shared-hero-flag-item">
          <a
            href={sharedHero.languageFlags.find((flag) => flag.active)?.href ?? sharedHero.logoHomeHref}
            aria-label={heroLocale === "en" ? "Language" : heroLocale === "de" ? "Sprache" : "Språk"}
          >
            {sharedHero.languageFlags.find((flag) => flag.active)?.flag ?? "🇸🇪"}
          </a>
          <ul class="shared-hero-submenu shared-hero-flag-submenu">
            {sharedHero.languageFlags.map((flag) => <li><a href={flag.href} aria-label={flag.label}>{flag.flag}</a></li>)}
          </ul>
        </li>
      </ul>
    </nav>
  </div>

  <div class="shared-hero-mobile-nav-shell" data-hero-mobile-nav-shell>
    <div class="shared-hero-mobile-nav-bar">
      <button
        class="shared-hero-menu-toggle"
        type="button"
        aria-label={menuToggleAria}
        aria-expanded="false"
        aria-haspopup="true"
        aria-controls="shared-hero-mobile-menu"
        data-hero-menu-toggle
      >
        <span class="shared-hero-menu-icon-open" aria-hidden="true">☰</span>
        <span class="shared-hero-menu-icon-close" aria-hidden="true">✕</span>
      </button>
    </div>
    <nav id="shared-hero-mobile-menu" class="shared-hero-mobile-menu" aria-label={navMobileAria} hidden>
      <ul class="shared-hero-mobile-menu-list">
        {
          sharedHero.menuItems.map((item) => (
            <li class="shared-hero-mobile-menu-item">
              {item.subMenu.length > 0 ? (
                <details class="shared-hero-mobile-menu-details">
                  <summary class="shared-hero-mobile-menu-summary">
                    <span class="shared-hero-mobile-menu-summary-main">
                      {item.href ? (
                        <a href={item.href}>{item.label}</a>
                      ) : (
                        <span class="shared-hero-mobile-menu-heading">{item.label}</span>
                      )}
                    </span>
                    <span class="shared-hero-mobile-menu-summary-chevron" aria-hidden="true">
                      ▾
                    </span>
                  </summary>
                  <ul class="shared-hero-mobile-submenu">
                    {item.subMenu.map((subItem) => <li><a href={subItem.href}>{subItem.label}</a></li>)}
                  </ul>
                </details>
              ) : item.href ? (
                <a href={item.href}>{item.label}</a>
              ) : (
                <span class="shared-hero-mobile-menu-heading">{item.label}</span>
              )}
            </li>
          ))
        }
        {
          sharedHero.ticketItem ? (
            <li class="shared-hero-mobile-menu-item shared-hero-ticket-item">
              <a href={sharedHero.ticketItem.href}>{sharedHero.ticketItem.label}</a>
            </li>
          ) : null
        }
        {
          mobileLanguageAlternates.map((flag) => (
            <li class="shared-hero-mobile-menu-item shared-hero-mobile-lang-item">
              <a href={flag.href} aria-label={flag.label}>
                <span class="shared-hero-mobile-lang-emoji" aria-hidden="true">{flag.flag}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
    </>
  ) : null}
</header>
)
}

<script>
  import "../../client-scripts/site-header.ts";
</script>
