---
import { GTM_CONTAINER_ID } from "../../lib/chrome/tracking-constants";

const gtmId = GTM_CONTAINER_ID;
const src = `https://www.googletagmanager.com/ns.html?id=${gtmId}`;
---

<noscript>
  <iframe
    src={src}
    height="0"
    width="0"
    style="display:none;visibility:hidden"
    title="Google Tag Manager"></iframe>
</noscript>
