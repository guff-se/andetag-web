---
import type { PageLayoutModel } from "../../lib/chrome/page-layout";
import { getSwedishFooterModel } from "../../lib/chrome/footer-sv";
import { getEnglishStockholmFooterModel } from "../../lib/chrome/footer-en-stockholm";
import { getEnglishBerlinFooterModel } from "../../lib/chrome/footer-en-berlin";
import { getGermanBerlinFooterModel } from "../../lib/chrome/footer-de-berlin";
import FooterSocialLinks from "./FooterSocialLinks.astro";

const { model } = Astro.props as { model: PageLayoutModel };

const berlinLocationFooter =
  model.footer.id === "chrome-ftr-en-berlin"
    ? getEnglishBerlinFooterModel()
    : model.footer.id === "chrome-ftr-de-berlin"
      ? getGermanBerlinFooterModel()
      : null;

const detailedFooter =
  model.footer.id === "chrome-ftr-sv-stockholm"
    ? getSwedishFooterModel()
    : model.footer.id === "chrome-ftr-en-stockholm"
      ? getEnglishStockholmFooterModel()
      : null;
---

{
berlinLocationFooter ? (
  <footer class="shared-footer-root" lang={model.footer.id === "chrome-ftr-de-berlin" ? "de" : "en"}>
    <div class="shared-footer-container">
      <nav
        class="shared-footer-grid shared-footer-grid--berlin-cols"
        aria-label={berlinLocationFooter.locationNavAriaLabel}
      >
        <section class="shared-footer-col">
          <ul>
            {
              berlinLocationFooter.locationLinkColumns[0].map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </section>
        <section class="shared-footer-col">
          <ul>
            {
              berlinLocationFooter.locationLinkColumns[1].map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </nav>

      <div class="shared-footer-bottom">
        <div class="shared-footer-copyright">{berlinLocationFooter.copyright}</div>
        <div class="shared-footer-privacy">
          <a href={berlinLocationFooter.privacyLink.href}>{berlinLocationFooter.privacyLink.label}</a>
        </div>
        <div class="shared-footer-socials" aria-label="Social links">
          <FooterSocialLinks links={berlinLocationFooter.socialLinks} />
        </div>
      </div>
    </div>
  </footer>
) : detailedFooter ? (
  <footer class="shared-footer-root">
    <div class="shared-footer-container">
      <div class="shared-footer-grid">
        <section class="shared-footer-col">
          <p>{detailedFooter.sections[0]?.title}</p>
          <ul>
            {detailedFooter.sections[0]?.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </section>
        <section class="shared-footer-col">
          <p>{detailedFooter.sections[1]?.title}</p>
          <ul>
            {detailedFooter.sections[1]?.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </section>
        <section class="shared-footer-col">
          <p>{detailedFooter.groupedSections[0]?.title}</p>
          <ul>
            {detailedFooter.groupedSections[0]?.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
          <p>{detailedFooter.groupedSections[1]?.title}</p>
          <ul>
            {detailedFooter.groupedSections[1]?.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>

      {detailedFooter.seoLinks.length > 0 ? (
        <p class="shared-footer-seo-links">
          {
            detailedFooter.seoLinks.map((link, index) => (
              <span>
                {index > 0 && <span> / </span>}
                <a href={link.href}>{link.label}</a>
              </span>
            ))
          }
        </p>
      ) : null}

      <div class="shared-footer-bottom">
        <div class="shared-footer-copyright">{detailedFooter.copyright}</div>
        <div class="shared-footer-privacy">
          <a href={detailedFooter.privacyLink.href}>{detailedFooter.privacyLink.label}</a>
        </div>
        <div class="shared-footer-socials" aria-label="Social links">
          <FooterSocialLinks links={detailedFooter.socialLinks} />
        </div>
      </div>
    </div>
  </footer>
) : (
  <footer class="footer-root">
    <div class="footer-container">
      <p class="hero-note">Footer variant: {model.footer.id}</p>
      <div class="footer-links" aria-label="Legal links">
        {
          model.footer.legalLinks.map((link) => (
            <a class="chip" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="footer-socials" aria-label="Social links">
        {
          model.footer.socialLinks.map((link) => (
            <a class="chip" href={link.href} rel="noreferrer" target="_blank">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </footer>
)
}
