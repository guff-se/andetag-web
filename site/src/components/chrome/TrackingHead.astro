---
/**
 * CookieConsent CMP bootstrap, GTM bootstrap, Google Consent Mode v2 defaults.
 *
 * Performance strategy (sequence):
 * 1. Consent defaults (all denied) fire synchronously: no tag ever fires
 *    without consent, regardless of script load order.
 * 2. CookieConsent is initialized as an early, lightweight module script.
 *    It emits consent updates on first consent, load, and preference changes.
 * 3. GTM is deferred to the `load` event; its `wait_for_update: 500` gives
 *    the CMP time to set consent before any GTM tag fires.
 */
import { GTM_CONTAINER_ID } from "../../lib/chrome/tracking-constants";

const gtmId = GTM_CONTAINER_ID;
---

<!-- Consent defaults: synchronous, tiny, must run before any tag manager. -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("consent", "default", {
    ad_storage: "denied",
    ad_user_data: "denied",
    ad_personalization: "denied",
    analytics_storage: "denied",
    functionality_storage: "denied",
    personalization_storage: "denied",
    security_storage: "granted",
    wait_for_update: 500,
  });
</script>
<script>
  import "../../client-scripts/cookie-consent-init.ts";
</script>
<!-- GTM: deferred to window.load so it does not delay LCP. -->
<script is:inline define:vars={{ gtmId }}>
  window.addEventListener("load", function () {
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != "dataLayer" ? "&l=" + l : "";
      j.async = true;
      j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, "script", "dataLayer", gtmId);
  });
</script>
