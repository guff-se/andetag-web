---
/**
 * Termly resource blocker, GTM bootstrap, Google Consent Mode v2 defaults.
 * Termly ID is the resource-blocker UUID from the Termly dashboard embed.
 *
 * Note: Termly’s GTM guide often recommends turning Auto Blocker off when GTM
 * orchestrates tags, because Auto Blocker can interfere with GTM. This site
 * uses `autoBlock=on` per operator choice; if GTM or Understory misbehaves,
 * try `autoBlock=off` and rely on GTM consent checks + the Termly template.
 */
import { GTM_CONTAINER_ID } from "../../lib/chrome/tracking-constants";

const gtmId = GTM_CONTAINER_ID;
const termlyResourceBlockerSrc =
  "https://app.termly.io/resource-blocker/45781ec1-8b4c-4a0c-acef-9815cd5eabb3?autoBlock=on";
---

<!-- Consent defaults before GTM (Termly + Termly GTM template update these when configured). -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("consent", "default", {
    ad_storage: "denied",
    ad_user_data: "denied",
    ad_personalization: "denied",
    analytics_storage: "denied",
    functionality_storage: "denied",
    personalization_storage: "denied",
    security_storage: "granted",
    wait_for_update: 500,
  });
</script>
<script is:inline src={termlyResourceBlockerSrc}></script>
<script is:inline define:vars={{ gtmId }}>
  (function (w, d, s, l, i) {
    w[l] = w[l] || [];
    w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
    var f = d.getElementsByTagName(s)[0],
      j = d.createElement(s),
      dl = l != "dataLayer" ? "&l=" + l : "";
    j.async = true;
    j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
    f.parentNode.insertBefore(j, f);
  })(window, document, "script", "dataLayer", gtmId);
</script>
