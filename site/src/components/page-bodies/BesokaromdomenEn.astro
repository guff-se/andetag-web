---
import ContentSection from "../content/ContentSection.astro";
import {
  STOCKHOLM_RATING,
  STOCKHOLM_TRAVELLERS_CHOICE,
  STOCKHOLM_TRIPADVISOR_URL,
} from "../../lib/content/stockholm-reviews";

/**
 * `site-html/en-stockholm-visitor-reviews.html` wp-page **3708**.
 * TripAdvisor slider shortcode after main copy: omitted per **EX-0012** (extends **EX-0002**).
 */
const bodyMarkdown = [
  "<h1>Visitor reviews of <span class=\"brand-wordmark\">ANDETAG</span> in Stockholm</h1>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is an art experience in central Stockholm, frequently reviewed by both local and international visitors.<br />Below is a curated selection of excerpts from Tripadvisor reviews.</p>",
  "<p><strong>Overview</strong></p>",
  "<ul>",
  `<li><p>${STOCKHOLM_RATING.reviewCount} total reviews</p></li>`,
  `<li><p>${STOCKHOLM_RATING.fiveStarReviewCount} five-star ratings</p></li>`,
  `<li><p>Average rating: ${STOCKHOLM_RATING.ratingValue} / ${STOCKHOLM_RATING.bestRating}</p></li>`,
  "<li><p>Top ranked art museum in Stockholm on TripAdvisor</p></li>",
  `<li><p>Awarded <strong>Tripadvisor Travellers&rsquo; Choice ${STOCKHOLM_TRAVELLERS_CHOICE.year}</strong></p></li>`,
  "</ul>",
  "<hr />",
  "<h3>What visitors mention</h3>",
  "<blockquote><p>&ldquo;A peaceful oasis in the middle of the city.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<blockquote><p>&ldquo;Beautiful, calm and thoughtfully designed.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<blockquote><p>&ldquo;A unique combination of textile, light and sound.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<blockquote><p>&ldquo;Easy to reach, close to H&ouml;torget.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<blockquote><p>&ldquo;A welcome pause from the city.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<blockquote><p>&ldquo;An experience you feel physically, not just mentally.&rdquo;<br />Tripadvisor review</p></blockquote>",
  "<hr />",
  "<h3>Why visitors recommend <span class=\"brand-wordmark\">ANDETAG</span></h3>",
  "<p>Visitors frequently highlight:</p>",
  "<ul>",
  "<li><p>Calm atmosphere and slow pace</p></li>",
  "<li><p>Immersive light and textile art</p></li>",
  "<li><p>Central Stockholm location</p></li>",
  "<li><p>Flexible visit length</p></li>",
  "</ul>",
  "<hr />",
  "<h3>Read more reviews</h3>",
  `<ul><li>Link to <a href="${STOCKHOLM_TRIPADVISOR_URL}" target="_blank" rel="noopener noreferrer"><span class="brand-wordmark">ANDETAG</span> on Tripadvisor</a></li></ul>`,
  "<hr />",
  "<h3>Related pages</h3>",
  "<ul>",
  "<li><p><a href=\"/en/stockholm/tickets/\"><strong>Tickets</strong></a></p></li>",
  "<li><p><a href=\"/en/stockholm/what-kind-of-experience/\"><strong>The experience</strong></a></p></li>",
  "<li><p><a href=\"/en/\"><strong>Visitor information</strong></a></p></li>",
  "</ul>",
].join("");
---

<div class="page-migrated page-besokaromdomen-sv">
  <ContentSection markdown={bodyMarkdown} />
</div>
