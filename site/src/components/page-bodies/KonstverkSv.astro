---
import "../../styles/artworks.css";
import { ARTWORKS } from "../../lib/content/artworks";
import ArtworkFilterBar from "../content/ArtworkFilterBar.astro";
import ArtworkGrid from "../content/ArtworkGrid.astro";
import ArtworkMap from "../embeds/ArtworkMap.astro";
import ArtworkModal from "../content/ArtworkModal.astro";
import InquiryForm from "../embeds/InquiryForm.astro";

const originals = ARTWORKS.filter((a) => a.series === "original");
const available = originals.filter((a) => a.status === "for-sale");
const sold = originals.filter((a) => a.status === "sold");
const gems = ARTWORKS.filter((a) => a.series === "gem");

const counts = {
  formatAll: available.length,
  formatLandscape: available.filter((a) => a.format === "landscape").length,
  formatPortrait: available.filter((a) => a.format === "portrait").length,
};

// Serialize artworks for modal JS — order: available originals, gems, sold originals
const modalOrder = [...available, ...gems, ...sold];
const artworksJson = JSON.stringify(modalOrder.map((a) => ({
  id: a.id, series: a.series, number: a.number ?? null,
  edition: a.edition ?? null,
  titleSv: a.title.sv, titleEn: a.title.en,
  year: a.year, w: a.dimensionsCm.w, h: a.dimensionsCm.h,
  format: a.format, status: a.status, priceSek: a.priceSek ?? null,
  locationSv: a.location.label.sv, locationEn: a.location.label.en,
  images: a.images.map((img) => ({
    src: img.src, webp640: img.webp640, webp960: img.webp960,
    fullSrc: img.fullSrc ?? null, mood: img.mood,
    altSv: img.alt.sv, altEn: img.alt.en,
  })),
})));
---

<div class="page-migrated page-artworks" lang="sv">
  <script type="application/json" id="artworks-json" set:html={artworksJson}></script>

  <header class="page-artworks__lead">
    <h1>Andetagverken</h1>
    <p>
      Femtio originalverk i optisk fibertextil, vävda för att andas med rummet de hänger i.
      Att förvärva ett verk är att gå in i ett tyst nätverk av samtidigt andande rum, från
      Stockholm och vidare ut i världen.
    </p>
    <p>
      Bredvid originalserien finns tre Gems, mindre verk i upplagor om sex eller tio.
      Skriv till oss om något fångar din blick. Vi svarar i lugn takt.
    </p>
    <p class="page-artworks__counts" aria-label="Antal verk i serien">
      <span>Originalserie: 50 verk</span>
      <span>Gems: 3 verk i upplagor</span>
    </p>
  </header>

  <section class="page-artworks__section" aria-labelledby="originals-heading-sv">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Andetag no. 1 till 50</p>
      <h2 class="page-artworks__section-heading" id="originals-heading-sv">Andetag Originals</h2>
      <p class="page-artworks__section-intro">
        Varje original är ett unikt verk. Storlek, ljus och rörelse skiljer dem åt; samma
        andning bär dem alla.
      </p>
    </header>

    <ArtworkFilterBar language="sv" counts={counts} />
    <ArtworkGrid available={available} language="sv" gridId="originals" eagerFirst={true} />
  </section>

  <section class="page-artworks__section" aria-labelledby="gems-heading-sv">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Tre verk i upplagor</p>
      <h2 class="page-artworks__section-heading" id="gems-heading-sv">Andetag Gems</h2>
      <p class="page-artworks__section-intro">
        En förfinad fortsättning på Andetagserien. Varje verk bär samma kontemplativa djup
        och fina energi som de större originalen, destillerat till en mer intim skala.
      </p>
    </header>

    <ArtworkGrid available={gems} language="sv" gridId="gems" />
  </section>

  <ArtworkMap artworks={sold} language="sv" />

  <section class="page-artworks__section" aria-labelledby="sold-heading-sv">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Original</p>
      <h2 class="page-artworks__section-heading" id="sold-heading-sv">I samling ({sold.length})</h2>
    </header>

    <ArtworkGrid available={sold} language="sv" gridId="sold" />
  </section>

  <ArtworkModal language="sv" />

  <p class="page-artworks__commissioned">
    Beställningsverk är tillgängliga på förfrågan. Om du har en specifik plats,
    ett sammanhang eller en vision i åtanke berättar vi gärna mer om möjligheterna.
    Använd formuläret nedan för att höra av dig.
  </p>

  <InquiryForm language="sv" />

  <section class="content-section align-left">
    <div class="content-section-body">
      <p>
        Vill du veta mer om hur verken görs? Läs om
        <a href="/sv/stockholm/optisk-fibertextil/">den optiska fibertextilen</a>
        och om
        <a href="/sv/stockholm/om-konstnarerna-malin-gustaf-tadaa/">konstnärerna bakom serien</a>.
      </p>
    </div>
  </section>
</div>
