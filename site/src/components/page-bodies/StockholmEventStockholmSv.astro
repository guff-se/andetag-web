---
import StockholmSeoLandingSv from "./StockholmSeoLandingSv.astro";

/**
 * SEO landing cloned from `StockholmAttGoraSv.astro` (same shell as `stockholm-att-gora-stockholm.html`).
 * Distinct URL and meta for “event i Stockholm” / “vad händer i Stockholm”.
 */
const introMarkdown = [
  "<p>Söker du tips på vad som händer i Stockholm, eller ett event i Stockholm utan speaker, mingel och stress?</p>",
  "<p>Många listor handlar om tempo, folk och köer. Här är något annat.</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> är en plats att göra en sak: stanna.</p>",
  "<p>Låt ögonen vila i vackra ljusspel.</p>",
  "<p>Andas.</p>",
  "<p>Det räcker.</p>",
].join("");
---

<StockholmSeoLandingSv
  galleryId="stockholm-event-stockholm"
  h1Text="Event i Stockholm när du vill välja stillhet"
  introMarkdown={introMarkdown}
/>
