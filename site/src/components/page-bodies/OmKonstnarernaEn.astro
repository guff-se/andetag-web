---
import ContentSection from "../content/ContentSection.astro";
import ResponsiveInlinePicture from "../ui/ResponsiveInlinePicture.astro";
import { artWeekOpeningLeadAside } from "../../lib/content/stockholm-body-responsive-images";

/**
 * `site-html/en-about-the-artists-malin-gustaf-tadaa.html` wp-page (Polylang English).
 * Layout mirrors `OmKonstnarernaSv.astro` (same grids, figures, and CSS scope).
 * Bio HTML lives in the frontmatter so `<` in strings is not parsed as Astro markup on `set:html`.
 */
const openingMarkdown = [
  "<h1>Malin &amp; Gustaf Tadaa</h1>",
  "<p>Malin and Gustaf Tadaa are an artist duo based in Stockholm, working at the intersection of art, technology, and human presence. They have collaborated since 2011 and have been married since 2017. Their shared practice moves between light, textile, code, and interaction, inviting visitors to step into the work as participants rather than observers.</p>",
  "<p>In 2019, their exhibition <a href=\"https://tadaa.se/portfolio/emerging-sensation/\"><strong>Emerging Sensation</strong></a> was presented in the former nuclear reactor hall R1 in Stockholm. The exhibition sold out, welcoming more than 4,000 visitors over two weeks. Through optical fiber, light, interactive technology, and augmented reality, the work explored life's evolution and humanity's place within a technological context. The boundary between art and technology dissolved, leaving space for reflection, presence, and participation.</p>",
].join("");

const malinBioHtml =
  "<p><strong>Malin Bobeck Tadaa</strong> is an award-winning textile artist based in Stockholm. Through a self-developed method, she weaves optical fiber, light, sensors, and electronics into textile structures. The resulting works combine materiality, light, and touch, often inviting the visitor into an active role.</p><p>Her artistic practice is inspired by the human imagination, the deep sea, outer space, and worlds that lie beyond everyday perception. Through spatial installations, she creates shifted perspectives and a quiet sense of being somewhere else.</p>";

const gustafBioHtml =
  "<p><strong>Gustaf Josefsson Tadaa</strong> is an artist, serial entrepreneur, and speaker with over 25 years of experience in participatory culture and interactive art.</p><p>His artistic exploration is rooted in the idea that technology is profoundly human, and that through our interaction with it, we can better understand ourselves.</p><p>Gustaf is a self-taught programmer and has worked with art, technology, and spatial experiences for more than two decades. In parallel, he has been active as a speaker on future and societal issues, with a consistent focus on the human dimension of technology.</p>";

const teamMarkdown =
  "<h2>The Team Behind Andetag</h2>" +
  "<p><strong>Artists:</strong> Malin &amp; Gustaf Tadaa</p><p><strong>Art Production:</strong> Cecilia Pfaff</p><p><strong>Exhibition Production:</strong> Linnéa Appert.</p><p><strong>Original Music and Sound Production:</strong> <a href=\"https://povelolsson.com/\">Povel Olsson</a> and Gustaf Tadaa.</p><p><strong>Museum Manager:</strong> Fabian Macklin</p>";
---

<div class="page-migrated page-om-konstnarerna-sv">
  <div class="page-om-konstnarerna-sv__lead-grid two-col-align-top">
    <ContentSection markdown={openingMarkdown} />
    <aside class="page-om-konstnarerna-sv__lead-aside" aria-label="Image and link">
      <figure class="page-om-konstnarerna-sv__figure page-om-konstnarerna-sv__figure--hero">
        <ResponsiveInlinePicture
          sources={artWeekOpeningLeadAside}
          alt=""
          width={1024}
          height={683}
          loading="eager"
          fetchpriority="high"
        />
      </figure>
      <p class="page-om-konstnarerna-sv__lead-link">
        <a href="https://tadaa.se">Read more at tadaa.se</a>
      </p>
    </aside>
  </div>
  <div class="page-om-konstnarerna-sv__duo-grid">
    <div class="page-om-konstnarerna-sv__duo-col">
      <figure class="page-om-konstnarerna-sv__figure page-om-konstnarerna-sv__figure--portrait">
        <img
          src="/wp-content/uploads/2024/12/Malin-Tadaa-Andetag-2025-face-1-1024x1024.jpg"
          width={1024}
          height={1024}
          alt="Portrait of Malin Tadaa"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="content-section-body" set:html={malinBioHtml}></div>
    </div>
    <div class="page-om-konstnarerna-sv__duo-col">
      <figure class="page-om-konstnarerna-sv__figure page-om-konstnarerna-sv__figure--portrait">
        <img
          src="/wp-content/uploads/2024/12/Gustaf-Tadaa-Andetag-2025-face-1-1024x1024.jpg"
          width={1024}
          height={1024}
          alt="Portrait of Gustaf Tadaa"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="content-section-body" set:html={gustafBioHtml}></div>
    </div>
  </div>
  <ContentSection markdown={teamMarkdown} />
</div>
