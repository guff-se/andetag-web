---
import { corporateEventsGroupBody } from "../../lib/content/stockholm-body-responsive-images";
import StockholmSeoLandingEn from "./StockholmSeoLandingEn.astro";

/** English peer of `StockholmAttGoraSv.astro`; Swedish source `stockholm-att-gora-stockholm.html`. */
const introMarkdown = [
  "<p>Looking for things to do in Stockholm today?</p>",
  "<p>Something that does not need heavy planning, big-event tickets, or perfect weather?</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is a place to do one thing: stay.</p>",
  "<p>Open year-round, near Hötorget in central Stockholm. Drop in after work, midweek, or on a Sunday afternoon.</p>",
  "<p>Let your eyes rest in slow light.</p>",
  "<p>Breathe.</p>",
  "<p>That is enough.</p>",
].join("");

const introImage = {
  sources: corporateEventsGroupBody,
  alt: "Four visitors seated together before a large wall of luminous textile sculptures at ANDETAG.",
  width: 960,
  height: 687,
};
---

<StockholmSeoLandingEn
  galleryId="stockholm-en-things-to-do"
  h1Text="Something calm to do in Stockholm"
  introMarkdown={introMarkdown}
  introImage={introImage}
/>
