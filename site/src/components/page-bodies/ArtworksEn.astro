---
import "../../styles/artworks.css";
import { ARTWORKS } from "../../lib/content/artworks";
import ArtworkFilterBar from "../content/ArtworkFilterBar.astro";
import ArtworkGrid from "../content/ArtworkGrid.astro";
import ArtworkMap from "../embeds/ArtworkMap.astro";
import ArtworkModal from "../content/ArtworkModal.astro";
import InquiryForm from "../embeds/InquiryForm.astro";

const originals = ARTWORKS.filter((a) => a.series === "original");
const available = originals.filter((a) => a.status === "for-sale");
const sold = originals.filter((a) => a.status === "sold");
const gems = ARTWORKS.filter((a) => a.series === "gem");

const counts = {
  formatAll: available.length,
  formatLandscape: available.filter((a) => a.format === "landscape").length,
  formatPortrait: available.filter((a) => a.format === "portrait").length,
};

// Serialize artworks for modal JS — order: available originals, gems, sold originals
const modalOrder = [...available, ...gems, ...sold];
const artworksJson = JSON.stringify(modalOrder.map((a) => ({
  id: a.id, series: a.series, number: a.number ?? null,
  edition: a.edition ?? null,
  titleSv: a.title.sv, titleEn: a.title.en,
  year: a.year, w: a.dimensionsCm.w, h: a.dimensionsCm.h,
  type: a.type ?? null,
  format: a.format, status: a.status, priceSek: a.priceSek ?? null,
  locationSv: a.location.label.sv, locationEn: a.location.label.en,
  images: a.images.map((img) => ({
    src: img.src, webp640: img.webp640, webp960: img.webp960,
    fullSrc: img.fullSrc ?? null, mood: img.mood,
    altSv: img.alt.sv, altEn: img.alt.en,
  })),
})));
---

<div class="page-migrated page-artworks" lang="en">
  <script type="application/json" id="artworks-json" set:html={artworksJson}></script>

  <header class="page-artworks__lead">
    <h1>The Andetag Artworks</h1>
    <p>
      Fifty original works in optical fibre textile, woven to breathe with the rooms
      they live in. To acquire one is to step into a quiet network of breathing rooms,
      from Stockholm and out into the world.
    </p>
    <p>
      Alongside the original series are three Gems, smaller works in editions of six
      or ten. Write to us if a piece holds your gaze.
    </p>
  </header>

  <section class="page-artworks__section" aria-labelledby="originals-heading-en">
    <header class="page-artworks__section-head">
      <h2 class="page-artworks__section-heading" id="originals-heading-en">Andetag Originals</h2>
      <p class="page-artworks__section-intro">
        The original Andetag series: fifty works, each hand-tailored in size, light,
        and motion. The series premiered at Art Miami in December 2023 and remains
        limited. No two pieces are the same; the same breath carries them all.
        Also available as <a href="#gems-heading-en">Andetag Gems</a>, a smaller-format edition series.
        Read about <a href="/en/stockholm/optical-fibre-textile/">the optical fibre textile</a> that forms the foundation of every work.
      </p>
    </header>

    <ArtworkFilterBar language="en" counts={counts} />
    <ArtworkGrid available={available} language="en" gridId="originals" eagerFirst={true} />
  </section>

  <section class="page-artworks__section" aria-labelledby="gems-heading-en">
    <header class="page-artworks__section-head">
      <h2 class="page-artworks__section-heading" id="gems-heading-en">Andetag Gems</h2>
      <p class="page-artworks__section-intro">
        A refined continuation of the Andetag body of work, premiered at Stockholm Art
        Week in May 2025. Each piece carries the same contemplative depth and delicate
        energy as the <a href="#originals-heading-en">larger originals</a>, distilled into a more intimate scale.
        Read about <a href="/en/stockholm/about-the-artists-malin-gustaf-tadaa/">the artists behind the series</a>.
      </p>
    </header>

    <ArtworkGrid available={gems} language="en" gridId="gems" />
  </section>

  <section class="page-artworks__section" aria-labelledby="map-heading-en">
    <header class="page-artworks__section-head">
      <h2 class="page-artworks__section-heading" id="map-heading-en">In collections around the world</h2>
      <p class="page-artworks__section-intro">
        More than twenty Andetag works are held by private collectors across the world,
        in Seattle, New York, Miami, Costa Rica, Portugal, and Sweden. Each one is
        connected to every other through the internet, breathing together in the same
        shared rhythm.
      </p>
    </header>

    <ArtworkMap artworks={sold} language="en" />
  </section>

  <section class="page-artworks__section" aria-labelledby="sold-heading-en">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Originals</p>
      <h2 class="page-artworks__section-heading" id="sold-heading-en">In a collection ({sold.length})</h2>
    </header>

    <ArtworkGrid available={sold} language="en" gridId="sold" />
  </section>

  <ArtworkModal language="en" />

  <p class="page-artworks__commissioned">
    Commissioned works are available upon request. If you have a specific space,
    context, or vision in mind, we are glad to explore possibilities with you.
    Use the form below to get in touch.
  </p>

  <InquiryForm language="en" />

</div>
