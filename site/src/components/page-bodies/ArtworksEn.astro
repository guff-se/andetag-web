---
import "../../styles/artworks.css";
import { ARTWORKS, getCatalogueTotals } from "../../lib/content/artworks";
import ArtworkFilterBar from "../content/ArtworkFilterBar.astro";
import ArtworkGrid from "../content/ArtworkGrid.astro";
import ArtworkMap from "../embeds/ArtworkMap.astro";
import InquiryForm from "../embeds/InquiryForm.astro";

const originals = ARTWORKS.filter((a) => a.series === "original");
const gems = ARTWORKS.filter((a) => a.series === "gem");
const totals = getCatalogueTotals(ARTWORKS);

const counts = {
  statusAll: originals.length,
  statusForSale: originals.filter((a) => a.status === "for-sale").length,
  statusSold: originals.filter((a) => a.status === "sold").length,
  formatAll: originals.length,
  formatLandscape: originals.filter((a) => a.format === "landscape").length,
  formatPortrait: originals.filter((a) => a.format === "portrait").length,
  formatDiptych: originals.filter((a) => a.format === "diptych").length,
};
---

<div class="page-migrated page-artworks" lang="en">
  <header class="page-artworks__lead">
    <h1>The Andetag Artworks</h1>
    <p>
      Fifty original works in optical fibre textile, woven to breathe with the rooms
      they live in. To acquire one is to step into a quiet network of breathing rooms,
      from Stockholm and out into the world.
    </p>
    <p>
      Alongside the original series are three Gems, smaller works in editions of six
      or ten. Write to us if a piece holds your gaze. We will reply at a calm pace.
    </p>
    <p class="page-artworks__counts" aria-label="Number of works in the series">
      <span>Original series: 50 works</span>
      <span>Gems: 3 works in editions</span>
    </p>
  </header>

  <ArtworkMap artworks={ARTWORKS} language="en" />

  <section class="page-artworks__section" aria-labelledby="originals-heading">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Originals</p>
      <h2 class="page-artworks__section-heading" id="originals-heading">Andetag no. 1 to 50</h2>
      <p class="page-artworks__section-intro">
        Each original is one of a kind. Their size, light, and motion differ; the same
        breath carries them all.
      </p>
    </header>

    <ArtworkFilterBar language="en" counts={counts} />
    <ArtworkGrid artworks={originals} language="en" gridId="originals" eagerFirst={true} />
  </section>

  <section class="page-artworks__section" aria-labelledby="gems-heading">
    <header class="page-artworks__section-head">
      <p class="page-artworks__section-eyebrow">Gems</p>
      <h2 class="page-artworks__section-heading" id="gems-heading">Three works in editions</h2>
      <p class="page-artworks__section-intro">
        Three smaller works in optical fibre textile, woven in editions of six or ten.
        The same material, the same breath, on a quieter scale.
      </p>
    </header>

    <ArtworkGrid artworks={gems} language="en" gridId="gems" />
  </section>

  <InquiryForm language="en" />

  <section class="content-section align-left">
    <div class="content-section-body">
      <p>
        Curious about how the works are made? Read about
        <a href="/en/stockholm/optical-fibre-textile/">the optical fibre textile</a>
        and
        <a href="/en/stockholm/about-the-artists-malin-gustaf-tadaa/">the artists behind the series</a>.
      </p>
    </div>
  </section>
</div>
