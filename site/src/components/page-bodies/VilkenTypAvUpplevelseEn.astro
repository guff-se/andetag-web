---
import ContentSection from "../content/ContentSection.astro";
import GallerySection from "../content/GallerySection.astro";
import { stockholmMarketingGalleryHomeEn } from "../../lib/content/stockholm-marketing-gallery";

/**
 * `site-html/en-stockholm-what-kind-of-experience.html` wp-page.
 */
const h1Html =
  "<h1>What kind of experience is <span class=\"brand-wordmark\">ANDETAG</span>?</h1>";

const introProse =
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is an ongoing project of globally connected artworks, installations and public spaces. It is an immersive art experience that envelops you in softness.</p>" +
  "<p>Through textile, light and music, it invites you to connect to a rhythm larger than yourself, connecting you to a sense of stillness and wonder.</p>" +
  "<p>It is a place to breathe, in a world that often forgets to.</p>";

const forYouMarkdown =
  "<h2>This is for you if you want</h2>" +
  "<ul>" +
  "<li><p>A place to land, to slow down and breathe</p></li>" +
  "<li><p>A hypnotic immersive experience with light, sound and music</p></li>" +
  "<li><p>To sit down by yourself, or lie down and cuddle with someone</p></li>" +
  "<li><p>An experience shaped by stillness rather than stimulation</p></li>" +
  "</ul>";

const notForYouMarkdown =
  "<h2>This might not be for you if you want</h2>" +
  "<ul>" +
  "<li><p>High tempo and stimulation</p></li>" +
  "<li><p>A social event with or place for loud conversations</p></li>" +
  "<li><p>A space designed for movement and activity</p></li>" +
  "<li><p>A party</p></li>" +
  "</ul>";

const concreteMarkdown =
  "<h2>What it is, in plain terms</h2>" +
  "<p><strong>Light-based textile art</strong><br />The works are woven from optical fibers and traditional textile materials. Light travels inside the fabric itself, powered by thousands of small programmable LEDs. The textile glows from within and changes slowly over time.</p>" +
  "<p><strong>A shared breathing rhythm</strong><br />Sound and light are synchronized to a slow, meditative breath. The rhythm is based on a real breath recording captured during meditation. The system never repeats. Each moment is shown only once. If you want, you may breathe along.</p>" +
  "<p><strong>Three connected spaces</strong><br />The exhibition moves through a gallery for close viewing, a darker transition space, and a fully immersive breathing room. In the final room, there are blankets and pillows, and you are invited to sit or lie down and stay with the light and sound.</p>" +
  "<p><strong>Music that leads you</strong><br />The music of <span class=\"brand-wordmark\">ANDETAG</span> is composed as small journeys, intended to guide the listener inward. Each piece has its own character and is synchronized with the breath and visualized through light.</p>" +
  "<p><strong>A global breath</strong><br />Each <span class=\"brand-wordmark\">ANDETAG</span> artwork is connected via the internet to synchronize with others around the world. Wherever they are placed, the works breathe together. There are currently works in the United States, Costa Rica, Mexico, and Sweden breathing in sync with the exhibition and with you.</p>" +
  "<p>Ready to visit? <a href=\"/en/stockholm/tickets/\">Book tickets</a>. Neurodivergent visitors can also read our <a href=\"/en/stockholm/neurodivergent-art/\">sensory-friendly pre-visit information</a>.</p>" +
  "<p>Want to share the experience with colleagues? Read about <a href=\"/en/stockholm/corporate-events/\">corporate events at <span class=\"brand-wordmark\">ANDETAG</span></a>: kickoffs, conferences, and team building in the same calm rooms.</p>" +
  "<p>Welcome.</p>";

const heroImage = {
  src: "/wp-content/uploads/2026/01/TADAA-LONG-V1.00_07_24_06.Still008-2-1024x576.jpg",
  width: 1024,
  height: 576,
  alt: "Visitors resting together on cushions in a darkened room surrounded by breathing light art at ANDETAG",
} as const;
---

<div class="page-migrated page-vilken-typ-sv">
  <section class="content-section align-left" aria-labelledby="vilken-typ-h1-en">
    <div id="vilken-typ-h1-en" class="content-section-body" set:html={h1Html} />
  </section>
  <div class="page-vilken-typ-sv__intro">
    <div class="content-section-body" set:html={introProse} />
    <figure class="page-vilken-typ-sv__hero-figure">
      <img
        src={heroImage.src}
        width={heroImage.width}
        height={heroImage.height}
        alt={heroImage.alt}
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
  <div class="page-vilken-typ-sv__lists">
    <ContentSection markdown={forYouMarkdown} />
    <ContentSection markdown={notForYouMarkdown} />
  </div>
  <GallerySection
    images={[...stockholmMarketingGalleryHomeEn]}
    mobileMode="carousel"
    galleryId="vilken-typ-en"
    carouselAriaLabel="Image gallery"
    galleryNavLocale="en"
  />
  <ContentSection markdown={concreteMarkdown} />
</div>
