---
import ContentSection from "../content/ContentSection.astro";
import GallerySection from "../content/GallerySection.astro";

/**
 * `site-html/en-stockholm-what-kind-of-experience.html` wp-page.
 */
const h1Html =
  "<h1>What kind of experience is <span class=\"brand-wordmark\">ANDETAG</span>?</h1>";

const introProse =
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is a calm, breathing art experience. Textile, light and sound, built for stillness and presence.</p>" +
  "<p>It is not an event.<br />Not a spectacle.<br />Not something to rush through.</p>" +
  "<p>It is a place to sit down.<br />To breathe.<br />To stay for a while.</p>";

const forYouMarkdown =
  "<h3>This is for you if you want</h3>" +
  "<ul>" +
  "<li><p>A quiet space in the city</p></li>" +
  "<li><p>Light-based art you can sit with, not consume quickly</p></li>" +
  "<li><p>A slow rhythm that allows the body to settle</p></li>" +
  "<li><p>An immersive room where nothing demands your attention</p></li>" +
  "<li><p>An experience shaped by stillness rather than stimulation</p></li>" +
  "</ul>";

const notForYouMarkdown =
  "<h3>This might not be for you if you want</h3>" +
  "<ul>" +
  "<li><p>A fast exhibition you finish in minutes</p></li>" +
  "<li><p>Big spectacle, loud moments, or constant stimulation</p></li>" +
  "<li><p>A guided narrative or clear storyline</p></li>" +
  "<li><p>A social event with high energy</p></li>" +
  "<li><p>A space designed for movement and activity</p></li>" +
  "</ul>";

const galleryImages = [
  {
    src: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-6074-scaled.jpg",
    fullSrc: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-6074-scaled.jpg",
    alt: "fine art stockholm",
  },
  {
    src: "/wp-content/uploads/2024/11/Andetag-13-35-copy-2.jpg",
    fullSrc: "/wp-content/uploads/2024/11/Andetag-13-35-copy-2.jpg",
    alt: "optical fiber art textile installation",
  },
  {
    src: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-5983-scaled.jpg",
    fullSrc: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-5983-scaled.jpg",
    alt: "a perfect place for a date in stockholm",
  },
  {
    src: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-6038-scaled.jpg",
    fullSrc: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-6038-scaled.jpg",
    alt: "calm down in stockholm",
  },
  {
    src: "/wp-content/uploads/2024/11/Andetag-10-53-copy-2.jpg",
    fullSrc: "/wp-content/uploads/2024/11/Andetag-10-53-copy-2.jpg",
    alt: "unique light art stockholm",
  },
  {
    src: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-59311-scaled.jpg",
    fullSrc: "/wp-content/uploads/2025/01/ANDETAG-Tadaa-Photo-Johan-Eriksson-_-TERRAN-59311-scaled.jpg",
    alt: "a meditative experience in stockholm",
  },
  {
    src: "/wp-content/uploads/2024/11/Andetag-19-508-copy.jpg",
    fullSrc: "/wp-content/uploads/2024/11/Andetag-19-508-copy.jpg",
    alt: "mindfulness exhibition stockholm",
  },
  {
    src: "/wp-content/uploads/2024/11/Andetag-10-69-copy.jpg",
    fullSrc: "/wp-content/uploads/2024/11/Andetag-10-69-copy.jpg",
    alt: "things to do in stockholm",
  },
] as const;

const concreteMarkdown =
  "<h2>What it is, in plain terms</h2>" +
  "<p><strong>Light-based textile art</strong><br />The works are woven from optical fibers and traditional textile materials. Light travels inside the fabric itself, powered by thousands of small programmable LEDs. The textile glows from within and changes slowly over time.</p>" +
  "<p><strong>A shared breathing rhythm</strong><br />Sound and light are synchronized to a slow, meditative breath. The rhythm is based on a real breath recording captured during meditation. The system never repeats. Each moment is shown only once. If you want, you may breathe along.</p>" +
  "<p><strong>Three connected spaces</strong><br />The exhibition moves through a gallery for close viewing, a darker transition space, and a fully immersive breathing room. In the final room, there are blankets and pillows, and you are invited to sit or lie down and stay with the light and sound.</p>" +
  "<p><strong>Music that leads you</strong><br />The music of <span class=\"brand-wordmark\">ANDETAG</span> is composed as small journeys, intended to guide the listener inward. Each piece has its own character and is synchronized with the breath and visualized through light.</p>" +
  "<p><strong>A global breath</strong><br />Each <span class=\"brand-wordmark\">ANDETAG</span> artwork is connected via the internet to synchronize with others around the world. Wherever they are placed, the works breathe together. There are currently works in the United States, Costa Rica, Mexico, and Sweden breathing in sync with the exhibition and with you.</p>" +
  "<p>Welcome.</p>";

const heroImage = {
  src: "/wp-content/uploads/2026/01/TADAA-LONG-V1.00_07_24_06.Still008-2-1024x576.jpg",
  width: 1024,
  height: 576,
  alt: "",
} as const;
---

<div class="page-migrated page-vilken-typ-sv">
  <section class="content-section align-left" aria-labelledby="vilken-typ-h1-en">
    <div id="vilken-typ-h1-en" class="content-section-body" set:html={h1Html} />
  </section>
  <div class="page-vilken-typ-sv__intro">
    <div class="content-section-body" set:html={introProse} />
    <figure class="page-vilken-typ-sv__hero-figure">
      <img
        src={heroImage.src}
        width={heroImage.width}
        height={heroImage.height}
        alt={heroImage.alt}
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
  <div class="page-vilken-typ-sv__lists">
    <ContentSection markdown={forYouMarkdown} />
    <ContentSection markdown={notForYouMarkdown} />
  </div>
  <GallerySection images={[...galleryImages]} mobileMode="carousel" galleryId="vilken-typ-en" />
  <ContentSection markdown={concreteMarkdown} />
</div>
