---
import AccordionSection from "../content/AccordionSection.astro";
import BookingEmbed from "../embeds/BookingEmbed.astro";
import ButtonGroup from "../content/ButtonGroup.astro";
import ContentSection from "../content/ContentSection.astro";
import GallerySection from "../content/GallerySection.astro";
import HeroSection from "../content/HeroSection.astro";
import InfoFrame from "../content/InfoFrame.astro";
import MapEmbed from "../embeds/MapEmbed.astro";
import PartnersSection from "../content/PartnersSection.astro";
import StyledLink from "../ui/StyledLink.astro";
import TestimonialCarousel from "../content/TestimonialCarousel.astro";
import VideoEmbed from "../embeds/VideoEmbed.astro";
import ResponsiveInlinePicture from "../ui/ResponsiveInlinePicture.astro";
import { STOCKHOLM_BOOK_HERO_COVER } from "../../lib/chrome/assets";
import { mainRoomLookingBody, mainRoomMeditationBody } from "../../lib/content/stockholm-body-responsive-images";
import { stockholmMarketingGalleryHome } from "../../lib/content/stockholm-marketing-gallery";
import { stockholmTestimonialAggregateSv } from "../../lib/content/stockholm-testimonial-aggregate";
import { stockholmMarketingFaqSv } from "../../lib/page-registry/stockholm-marketing-faq-sv";
import {
  STOCKHOLM_TICKETS,
  STOCKHOLM_SEASON_PASS,
  STOCKHOLM_DAYTIME_WINDOW,
} from "../../lib/content/stockholm-offers";

/**
 * Swedish Stockholm home: body from `site-html/index.html`
 * (`data-elementor-type="wp-page"` post id 2). Head from `page-shell-meta.json`.
 * Intro lead photo: `main-room-looking.jpg` under `site/public/wp-content/uploads/2026/03/`. Art Yoga aside: `main-room-meditation.jpg` (same folder).
 * TripAdvisor shortcode: removed per **EX-0002**; English quotes in `TestimonialCarousel` with Swedish aggregate row (figures from besökaromdömen source).
 * Booking contact below widget: **EX-0010** (`info@andetag.museum`).
 */
const understoryCompanyId = "3b3aa7a7c2cd455b8f3a56cd81033110";

const artYogaBookingHref =
  "https://andetag.understory.io/experience/cc2f4ed4e1709b93a454a1e5abad6595";

const introLeadImage = {
  width: 1920,
  height: 1080,
  alt: "Besökare i silhuett som blickar upp mot lysande konst i ANDETAG",
} as const;

const artYogaAsideImage = {
  width: 1924,
  height: 1443,
  alt: "Person som mediterar omgiven av ljus och textilkonst under Art Yoga på ANDETAG",
} as const;

const introMarkdown = [
  "<p>Inne i <span class=\"brand-wordmark\">ANDETAG</span> står tiden stilla.</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> är en immersiv konstupplevelse i centrala Stockholm, där ljus, andning och musik möts i ett stilla museum nära Hötorget.</p>",
  "<p>I en tid där tempot ständigt ökar, får du en möjlighet att stilla din andning och låta dig svepas in i en förtrollande väv av former, ljus och ljud.</p>",
  "<p>Välkommen till <span class=\"brand-wordmark\">ANDETAG</span> – en plats för stillhet och förundran.</p>",
].join("");

const homeAccordionItems = [...stockholmMarketingFaqSv];

const biljetterIntroHtml = [
  "<p><span class=\"brand-wordmark\">ANDETAG</span> är en upplevelse som tar dig från vardagens stress in i en fridfull magisk värld.</p>",
  "<p>Du är välkommen att anlända före utsatt tid, förutsatt att vanlig öppettid råder. Du går igenom utställningen i din egen takt, och stannar tills du känner dig klar.</p>",
  "<p>Vi använder tidsbokning för att se till att inte för många anländer samtidigt. Platserna fylls snabbt, så se till att boka i tid.</p>",
].join("");

const _r = STOCKHOLM_TICKETS.find((t) => t.id === "regular")!;
const _ss = STOCKHOLM_TICKETS.find((t) => t.id === "student-senior")!;
const _y = STOCKHOLM_TICKETS.find((t) => t.id === "youth")!;

const homePriceFrameHtml = [
  `<p><strong>${_r.nameSv}:</strong> ${_r.price} kr (${_r.daytimePrice} kr dagtid)</p>`,
  `<p><strong>${_ss.nameSv}:</strong> ${_ss.price} kr (${_ss.daytimePrice} kr dagtid)</p>`,
  `<p><strong>${_y.nameSv}:</strong> ${_y.price} kr</p>`,
  `<p>Dagtidspris g\u00e4ller ${STOCKHOLM_DAYTIME_WINDOW.descriptionSv}</p>`,
].join("");

const seasonMarkdown = [
  `<p>Vill du g\u00f6ra <span class="brand-wordmark">ANDETAG</span> till en vana? Vi har m\u00e5nga bes\u00f6kare som gjort det till sin veckorutin att ta ett <span class="brand-wordmark">ANDETAG</span>.<br />F\u00f6r ${STOCKHOLM_SEASON_PASS.price} kr f\u00e5r du fri tillg\u00e5ng till upplevelsen i ${STOCKHOLM_SEASON_PASS.durationMonths} m\u00e5nader.</p>`,
  '<p><a href="/sv/stockholm/sasongskort/">Säsongskort</a> säljs i kassan. Om du visar din biljett får du dessutom avdrag på säsongskortet.</p>',
].join("");

const privatMarkdown = [
  "<p><span class=\"brand-wordmark\">ANDETAG</span> erbjuder skräddarsydda event morgon, dag, kväll och helg, perfekt för <a href=\"/sv/stockholm/foretagsevent/\">företag</a>, <a href=\"/sv/stockholm/gruppbokning/\">grupper</a> eller speciella tillfällen. Vi kan också erbjuda grupprabatter.</p>",
  '<p>Skicka ett mejl till <a href="mailto:info@tadaa.se">info@tadaa.se</a>, så hjälper vi dig!</p>',
].join("");

const artYogaMarkdown = [
  "<p>Art Yoga är en långsam yogaklass i Andetags omslutande konstmiljö i centrala Stockholm. En plats att röra sig, andas och landa, mitt i staden.</p>",
  "<p>Omgiven av glödande textilkonst och levande ljus leds klassen av yogaläraren <strong>Fabian Macklin</strong>. Rörelse, andning och närvaro vävs samman i ett mjukt tempo. Fokus ligger på att lyssna in kroppen snarare än att prestera.</p>",
  "<p>Klassen är öppen för både nybörjare och erfarna yogautövare.<br />Inga förkunskaper krävs.</p>",
].join("");

import { STOCKHOLM_FEATURED_REVIEWS } from "../../lib/content/stockholm-reviews";

const testimonialItems = STOCKHOLM_FEATURED_REVIEWS.map((r) => ({
  quote: r.quote,
  author: r.author,
}));

const partners = [
  {
    name: "Ateljé Lyktan",
    href: "https://www.ateljelyktan.se/",
    logoSrc: "/wp-content/uploads/2024/11/SVGOMG-Image-1.svg",
    logoAlt: "Ateljé Lyktan",
  },
  {
    name: "Toniton",
    href: "https://toniton.se/",
    logoSrc: "/wp-content/uploads/2024/11/Toniton-1.svg",
    logoAlt: "Toniton",
  },
  {
    name: "Fogia",
    href: "https://www.fogia.com/",
    logoSrc: "/wp-content/uploads/2024/12/Fogia-Logo.png",
    logoAlt: "Fogia",
  },
  {
    name: "dotAudio",
    href: "https://www.dotaudio.se/",
    logoSrc: "/wp-content/uploads/2024/11/g1036.png.png",
    logoAlt: "dotAudio",
  },
  {
    name: "Stoddard",
    href: "https://stoddard.se/",
    logoSrc: "/wp-content/uploads/2024/11/download.svg",
    logoAlt: "Stoddard",
  },
  {
    name: "Kvadrat",
    href: "https://www.kvadrat.dk/en",
    logoSrc: "/wp-content/uploads/2024/11/kvadrat-1024x217.png",
    logoAlt: "Kvadrat",
  },
  {
    name: "OBJECT CARPET",
    href: "https://www.object-carpet.com/",
    logoSrc: "/wp-content/uploads/2024/12/Object-Carpet-Logo.svg",
    logoAlt: "OBJECT CARPET",
  },
  {
    name: "Uniqorna",
    href: "https://uniqorna.com/",
    logoSrc: "/wp-content/uploads/2024/12/uniqorna-black.svg",
    logoAlt: "Uniqorna",
  },
] as const;

const kontaktMarkdown =
  "<p>För frågor gällande biljetter, evenemangsbokning eller generell information, vänligen kontakta: <a href=\"mailto:info@tadaa.se\">info@tadaa.se</a></p>";

const pressMarkdown = [
  "<h3>Press</h3>",
  "<p><strong>Presskontakt:</strong><br />Gustaf Tadaa<br />0709-854979<br />gustaf (a) tadaa.se</p>",
  '<p><a href="https://andetag.museum/presskit" target="_blank" rel="noreferrer noopener">Länk till presskit</a></p>',
].join("");

const contentsamarbetenMarkdown = [
  "<h3>Innehållssamarbeten</h3>",
  "<p>Är du en innehållsskapare, fotograf eller influencer som letar efter en unik och lysande bakgrund för ditt arbete? Vi vill gärna samarbeta!</p>",
  "<p>Vårt utrymme är en oas av glödande konst, stillhet och inspiration – perfekt för att skapa innehåll som verkligen är unikt.</p>",
  '<p>Skicka ett mejl till <a href="mailto:info@tadaa.se">info@tadaa.se</a> med din förfrågan.</p>',
  "<p>Låt oss skapa något magiskt tillsammans.</p>",
].join("");

const mapSrc =
  "https://maps.google.com/maps?q=Andetag%2C%20Kungsgatan%2039%2C%20111%2056%20Stockholm&t=m&z=15&output=embed&iwloc=near";

const mapLocationMarkdown =
  "<p>Du hittar <span class=\"brand-wordmark\">ANDETAG</span> i den centrala uppgången av Hötorgets Tunnelbanestation.</p><p><strong>Från tunnelbanan:</strong> Uppgång Kungsgatan (mitten av plattformen), sedan uppgång Kungsgatan mot Stureplan, Sveavägen mot Sergels torg.</p><p><strong>Från gatan:</strong> precis nedanför trappan i tunnelbanenedgången på Kungsgatan 39.</p>";

const vimeoSrc = "https://player.vimeo.com/video/1077937338";
---

<div class="page-migrated page-stockholm-home">
  <section class="content-section align-center page-stockholm-home__lead-eyebrow" aria-label="Inledning">
    <h3>Du har aldrig upplevt något liknande...</h3>
  </section>
  <div class="page-layout-with-aside page-stockholm-home__intro-booking">
    <div class="page-layout-with-aside__main">
      <ContentSection markdown={introMarkdown} />
      <figure class="page-stockholm-home__intro-figure">
        <ResponsiveInlinePicture
          sources={mainRoomLookingBody}
          width={introLeadImage.width}
          height={introLeadImage.height}
          alt={introLeadImage.alt}
        />
      </figure>
      <AccordionSection items={[...homeAccordionItems]} initialOpenIndex={null} />
      <div class="page-stockholm-home__loc-mobile" aria-label="Adress">
        <p class="page-stockholm-home__loc-mobile-text">
          <span class="brand-wordmark">ANDETAG</span><br />
          Kungsgatan 39, Hötorgets tunnelbana,<br /> Stockholm
        </p>
        <div class="page-stockholm-home__hitta-row">
          <StyledLink label="Hitta hit" href="#hitta" styleVariant="cta-primary" />
        </div>
      </div>
    </div>
    <aside class="page-layout-with-aside__aside" aria-label="Bokning">
      <BookingEmbed
        companyId={understoryCompanyId}
        language="sv"
        anchorId="book"
        heading="Boka direkt"
        unframed
        fallbackText="Bokningskalendern kunde inte laddas. Ladda om sidan eller kontakta oss om problemet kvarstår."
      />
    </aside>
  </div>

  <div class="page-stockholm-home__loc-desktop" aria-label="Adress">
    <p class="page-stockholm-home__loc-desktop-text">
      <span class="brand-wordmark">ANDETAG-</span>Kungsgatan 39, Hötorgets tunnelbana, Stockholm
    </p>
    <div class="page-stockholm-home__hitta-row">
      <StyledLink label="Hitta hit" href="#hitta" styleVariant="cta-primary" />
    </div>
  </div>

  <GallerySection
    images={[...stockholmMarketingGalleryHome]}
    mobileMode="carousel"
    galleryId="stockholm-home"
    carouselAriaLabel="Bildgalleri"
    galleryNavLocale="sv"
  />

  <div class="page-stockholm-home__tickets-columns">
    <div class="page-stockholm-home__tickets-col">
      <ContentSection heading="Biljetter" headingLevel="h2" markdown={biljetterIntroHtml} />
      <InfoFrame heading="Priser" headingLevel="h3" bodyHtml={homePriceFrameHtml} />
    </div>
    <div class="page-stockholm-home__tickets-col">
      <ContentSection heading="Säsongskort" headingLevel="h2" markdown={seasonMarkdown} />
      <ContentSection heading="Privat upplevelse" headingLevel="h2" markdown={privatMarkdown} />
    </div>
  </div>

  <HeroSection
    backgroundImage={STOCKHOLM_BOOK_HERO_COVER}
    ariaLabel="Ta ett andetag, boka biljett"
    ctas={[{ label: "Boka nu", href: "#book", variant: "outline" }]}
  >
    <h2 class="page-stockholm-home__book-hero-heading">
      <span class="page-stockholm-home__book-hero-heading-full">Ta Ett Andetag - Boka biljett</span>
      <span class="page-stockholm-home__book-hero-heading-short">Ta Ett Andetag</span>
    </h2>
  </HeroSection>

  <div class="page-layout-with-aside page-stockholm-home__art-yoga">
    <div class="page-layout-with-aside__main">
      <ContentSection heading="Art Yoga - varje tisdag kl. 17.00" headingLevel="h2" markdown={artYogaMarkdown} />
      <div class="page-stockholm-home__art-yoga-cta">
        <ButtonGroup
          buttons={[{ label: "Boka Yoga", href: artYogaBookingHref, variant: "primary", external: true }]}
        />
      </div>
    </div>
    <aside class="page-layout-with-aside__aside" aria-label="Art Yoga, foto">
      <figure class="page-stockholm-home__art-yoga-figure">
        <ResponsiveInlinePicture
          sources={mainRoomMeditationBody}
          width={artYogaAsideImage.width}
          height={artYogaAsideImage.height}
          alt={artYogaAsideImage.alt}
          sizes="(max-width: 900px) 100vw, min(42vw, 520px)"
        />
      </figure>
    </aside>
  </div>

  <TestimonialCarousel items={[...testimonialItems]} aggregate={{ ...stockholmTestimonialAggregateSv }} prevLabel="Föregående omdöme" nextLabel="Nästa omdöme" />

  <div class="page-migrated-cta page-stockholm-home__cta-after-testimonials">
    <ButtonGroup buttons={[{ label: "Upplev Andetag!", href: "#book", variant: "secondary" }]} />
  </div>

  <div class="page-stockholm-home__video-band">
    <VideoEmbed
      title="ANDETAG på Vimeo"
      src={vimeoSrc}
      fallbackText="Videon kunde inte laddas. Försök igen senare."
      posterWebp="/assets/video/vimeo-poster-1077937338.webp"
      posterJpeg="/assets/video/vimeo-poster-1077937338.jpg"
    />
  </div>

  <PartnersSection heading="Våra partners" headingLevel="h3" partners={[...partners]} />

  <ContentSection heading="Kontakt" headingLevel="h3" markdown={kontaktMarkdown} />

  <div class="page-stockholm-home__press-grid">
    <ContentSection markdown={pressMarkdown} />
    <ContentSection markdown={contentsamarbetenMarkdown} />
  </div>

  <div class="page-stockholm-home__cta-secondary-band">
    <div class="page-migrated-cta">
      <ButtonGroup buttons={[{ label: "Boka biljetter nu!", href: "#book", variant: "secondary" }]} />
    </div>
  </div>

  <section
    class="content-section page-stockholm-home__map"
    id="hitta"
    aria-labelledby="stockholm-home-map-heading"
  >
    <h2 id="stockholm-home-map-heading">Var är ANDETAG?</h2>
    <div class="page-stockholm-home__map-grid">
      <div class="content-section-body page-stockholm-home__map-copy" set:html={mapLocationMarkdown} />
      <div class="page-stockholm-home__map-frame">
        <MapEmbed
          title="Andetag, Kungsgatan 39, 111 56 Stockholm"
          src={mapSrc}
          unframed
          fallbackText="Kartan kunde inte laddas. Sök på Andetag, Kungsgatan 39 i din kartapp."
        />
      </div>
    </div>
  </section>
</div>
