---
import StockholmSeoLandingEn from "./StockholmSeoLandingEn.astro";

/** English peer of `StockholmAktivitetInomhusSv.astro`; Swedish source `stockholm-aktivitet-inomhus-stockholm.html`. */
const introMarkdown = [
  "<p>Looking for something to do in Stockholm that does not depend on the weather? An indoor activity where the pace slows down instead of speeding up?</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is a calm activity in central Stockholm. No screens. No interaction that demands a response. Just light, textile, and music, and soft rooms to be in.</p>",
  "<p>Here you can take the time you need.<br />Here you can breathe.</p>",
].join("");
---

<StockholmSeoLandingEn
  galleryId="stockholm-en-indoor-activity"
  h1Text="A calm, beautiful indoor activity"
  introMarkdown={introMarkdown}
/>
