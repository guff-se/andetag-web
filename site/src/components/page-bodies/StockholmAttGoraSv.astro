---
import { corporateEventsGroupBody } from "../../lib/content/stockholm-body-responsive-images";
import StockholmSeoLandingSv from "./StockholmSeoLandingSv.astro";

/**
 * `site-html/stockholm-att-gora-stockholm.html` wp-page **4507**.
 */
const introMarkdown = [
  "<p>Något att göra i Stockholm idag?</p>",
  "<p>Något som inte kräver planer, biljetter till stora evenemang eller vackert väder?</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> är en plats att göra en sak: stanna.</p>",
  "<p>Öppet året runt, mitt i stan vid Hötorget. Du kan komma in efter jobbet, mitt i veckan, eller en söndag eftermiddag.</p>",
  "<p>Låt ögonen vila i vackra ljusspel.</p>",
  "<p>Andas.</p>",
  "<p>Det räcker.</p>",
].join("");

const introImage = {
  sources: corporateEventsGroupBody,
  alt: "Fyra besökare sitter tillsammans framför en stor vägg av lysande textilskulpturer i ANDETAG.",
  width: 960,
  height: 687,
};
---

<StockholmSeoLandingSv
  galleryId="stockholm-att-gora"
  h1Text="Något lugnt att göra i Stockholm"
  introMarkdown={introMarkdown}
  introImage={introImage}
/>
