---
import ContentSection from "../content/ContentSection.astro";
import HeroSection from "../content/HeroSection.astro";

/**
 * English Art Yoga from `site-html/en-stockholm-art-yoga-en.html` wp-page.
 * Layout matches `ArtYogaSv.astro`: intro, `HeroSection` mid-band + outline CTA, practical block with list.
 * Image: same asset as Swedish page (`elementor-element-0a8e569` / `post-2519.css`).
 */
const bookingHref =
  "https://andetag.understory.io/experience/cc2f4ed4e1709b93a454a1e5abad6595";

const heroImageSrc =
  "/wp-content/uploads/2025/04/Art-Yoga-at-ANDETAG-photo-by-Johan-Eriksson-Terran-e1745929172557.jpeg";

const introHtml = [
  '<h1>Art Yoga at <span class="brand-wordmark">ANDETAG</span></h1>',
  "<h2>Yoga in Stockholm every Tuesday at 17:00</h2>",
  "<p>Art Yoga is a slow yoga class held inside Andetag&#8217;s immersive art environment in central Stockholm.<br />It is a place to move, breathe, and settle, in the middle of the city.</p>",
  "<p>Surrounded by glowing textile art and living light, the class is guided by yoga teacher <strong>Fabian Macklin</strong>.<br />Movement and breath unfold at a gentle pace, with attention on presence rather than performance.</p>",
  "<p>The class is open to both beginners and experienced practitioners.<br />No prior experience is required.</p>",
].join("");

const practicalHtml = [
  "<h3>Practical information</h3>",
  "<ul>",
  "<li>Time: Tuesdays at 17:00</li>",
  "<li>Book your slot online before you arrive</li>",
  "<li>Location: Andetag, Stockholm</li>",
  "<li>Doors close at 17:00. Please arrive on time.</li>",
  "<li>You are welcome to arrive 20 minutes early and stay after the class.</li>",
  "<li>Bring your own yoga mat if you wish. Practicing without a mat is also possible.</li>",
  "<li>There are no changing rooms or showers. Lockers are available for personal belongings.</li>",
  "</ul>",
  "<p>Art Yoga at Andetag is a quiet meeting between body and art.<br />One shared breath each week.</p>",
].join("");
---

<div class="page-migrated">
  <ContentSection markdown={introHtml} />
  <HeroSection
    backgroundImage={heroImageSrc}
    ariaLabel="Book Art Yoga"
    ctas={[
      {
        label: "Book Yoga",
        href: bookingHref,
        variant: "outline",
        external: true,
      },
    ]}
  />
  <ContentSection markdown={practicalHtml} />
</div>
