---
import AccordionSection from "../content/AccordionSection.astro";
import BookingEmbed from "../embeds/BookingEmbed.astro";
import ButtonGroup from "../content/ButtonGroup.astro";
import ContentSection from "../content/ContentSection.astro";
import GallerySection from "../content/GallerySection.astro";
import HeroSection from "../content/HeroSection.astro";
import InfoFrame from "../content/InfoFrame.astro";
import MapEmbed from "../embeds/MapEmbed.astro";
import PartnersSection from "../content/PartnersSection.astro";
import StyledLink from "../ui/StyledLink.astro";
import TestimonialCarousel from "../content/TestimonialCarousel.astro";
import VideoEmbed from "../embeds/VideoEmbed.astro";
import ResponsiveInlinePicture from "../ui/ResponsiveInlinePicture.astro";
import { STOCKHOLM_BOOK_HERO_COVER } from "../../lib/chrome/assets";
import { andrumLookingBody, andrumMeditationBody } from "../../lib/content/stockholm-body-responsive-images";
import { stockholmMarketingGalleryHome } from "../../lib/content/stockholm-marketing-gallery";
import { stockholmTestimonialAggregateEn } from "../../lib/content/stockholm-testimonial-aggregate";
import { stockholmMarketingFaqEn } from "../../lib/page-registry/stockholm-marketing-faq-en";
import {
  STOCKHOLM_TICKETS,
  STOCKHOLM_DAYTIME_WINDOW,
} from "../../lib/content/stockholm-offers";

/**
 * English Stockholm home: body from `site-html/en.html`
 * (`data-elementor-type="wp-page"` post id **907**). Canonical URL in legacy Yoast is `/en/`;
 * rebuilt route is **`/en/stockholm/`** with head from `page-shell-meta.json` (**EX-0007**).
 * TripAdvisor shortcode removed per **EX-0002**; carousel quotes match Swedish home (English copy).
 * Intro lead photo and Art Yoga aside: `andrum-looking.jpg`, `andrum-meditation.jpg` under `site/public/wp-content/uploads/2026/03/`.
 */
const understoryCompanyId = "3b3aa7a7c2cd455b8f3a56cd81033110";

const artYogaBookingHref =
  "https://andetag.understory.io/experience/cc2f4ed4e1709b93a454a1e5abad6595";

const introLeadImage = {
  width: 1920,
  height: 1080,
  alt: "Silhouette of a visitor looking up at luminous art at ANDETAG",
} as const;

const artYogaAsideImage = {
  width: 1924,
  height: 1443,
  alt: "Person meditating surrounded by light and textile art during Art Yoga at ANDETAG",
} as const;

const introMarkdown = [
  "<p>Inside <span class=\"brand-wordmark\">ANDETAG</span>, time stands still.</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is an immersive art experience in central Stockholm, where light, breath, and music meet in a quiet museum near Hötorget.</p>",
  "<p>In a world where the pace is constantly accelerating, You are invited to slow your breath and be enveloped in an enchanting tapestry of shapes, light, and sound.</p>",
  "<p>Welcome to <span class=\"brand-wordmark\">ANDETAG</span> – a place of stillness and wonder.</p>",
].join("");

const homeAccordionItems = [...stockholmMarketingFaqEn];

const biljetterIntroHtml = [
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is an experience that takes you from the stress of everyday life into a peaceful, magical world.</p>",
  "<p>You are welcome to arrive before your scheduled time, providing we are open normally. Explore the exhibition at your own pace and stay until you feel ready to leave.</p>",
  "<p>We use time slots to ensure that too many people don&#8217;t arrive at the same time. Spots fill up quickly, so make sure to book in advance.</p>",
].join("");

const _r = STOCKHOLM_TICKETS.find((t) => t.id === "regular")!;
const _ss = STOCKHOLM_TICKETS.find((t) => t.id === "student-senior")!;
const _y = STOCKHOLM_TICKETS.find((t) => t.id === "youth")!;
const _ay = STOCKHOLM_TICKETS.find((t) => t.id === "art-yoga")!;

const homePriceFrameHtml = [
  `<p><strong>${_r.nameEn}:</strong> ${_r.price} SEK (${_r.daytimePrice} SEK daytime)</p>`,
  `<p><strong>${_ss.nameEn}:</strong> ${_ss.price} SEK (${_ss.daytimePrice} SEK daytime)</p>`,
  `<p><strong>${_y.nameEn}:</strong> ${_y.price} SEK</p>`,
  `<p><strong>${_ay.nameEn}</strong> (Tuesdays 17.00\u201318.00): ${_ay.price} SEK</p>`,
  `<p>Daytime pricing: ${STOCKHOLM_DAYTIME_WINDOW.descriptionEn}</p>`,
].join("");

const seasonMarkdown = [
  "<p>Want to make <span class=\"brand-wordmark\">ANDETAG</span> a habit? Buy a <a href=\"/en/stockholm/season-pass/\">season pass</a> that gives you free access to the experience for six months!</p>",
  "<p>The <a href=\"/en/stockholm/season-pass/\">season pass</a> can be bought in the entrance. If you already purchased a ticket you can show it to get a discount on the season pass.</p>",
].join("");

const privatMarkdown = [
  "<p><span class=\"brand-wordmark\">ANDETAG</span> offer tailored events in the morning, daytime, evening, or weekends, perfect for <a href=\"/en/stockholm/corporate-events/\">companies</a>, <a href=\"/en/stockholm/group-bookings/\">groups</a>, or special occasions. We can also offer group discounts.</p>",
  '<p>Please send an email to <a href="mailto:info@tadaa.se">info@tadaa.se</a> and we will assist you!</p>',
].join("");

const artYogaMarkdown = [
  "<p>Art Yoga is a slow yoga class held inside Andetag&#8217;s immersive art environment in central Stockholm. It is a place to move, breathe, and settle, in the middle of the city.</p>",
  "<p>Surrounded by glowing textile art and living light, the class is guided by yoga teacher <strong>Fabian Macklin</strong>. Movement and breath unfold at a gentle pace, with attention on presence rather than performance.</p>",
  "<p>The class is open to both beginners and experienced practitioners.<br />No prior experience is required.</p>",
].join("");

import { STOCKHOLM_FEATURED_REVIEWS } from "../../lib/content/stockholm-reviews";

const testimonialItems = STOCKHOLM_FEATURED_REVIEWS.map((r) => ({
  quote: r.quote,
  author: r.author,
}));

const partners = [
  {
    name: "Ateljé Lyktan",
    href: "https://www.ateljelyktan.se/",
    logoSrc: "/wp-content/uploads/2024/11/SVGOMG-Image-1.svg",
    logoAlt: "Ateljé Lyktan",
  },
  {
    name: "Toniton",
    href: "https://toniton.se/",
    logoSrc: "/wp-content/uploads/2024/11/Toniton-1.svg",
    logoAlt: "Toniton",
  },
  {
    name: "Fogia",
    href: "https://www.fogia.com/",
    logoSrc: "/wp-content/uploads/2024/12/Fogia-Logo.png",
    logoAlt: "Fogia",
  },
  {
    name: "dotAudio",
    href: "https://www.dotaudio.se/",
    logoSrc: "/wp-content/uploads/2024/11/g1036.png.png",
    logoAlt: "dotAudio",
  },
  {
    name: "Stoddard",
    href: "https://stoddard.se/",
    logoSrc: "/wp-content/uploads/2024/11/download.svg",
    logoAlt: "Stoddard",
  },
  {
    name: "Kvadrat",
    href: "https://www.kvadrat.dk/en",
    logoSrc: "/wp-content/uploads/2024/11/kvadrat-1024x217.png",
    logoAlt: "Kvadrat",
  },
  {
    name: "OBJECT CARPET",
    href: "https://www.object-carpet.com/",
    logoSrc: "/wp-content/uploads/2024/12/Object-Carpet-Logo.svg",
    logoAlt: "OBJECT CARPET",
  },
  {
    name: "Uniqorna",
    href: "https://uniqorna.com/",
    logoSrc: "/wp-content/uploads/2024/12/uniqorna-black.svg",
    logoAlt: "Uniqorna",
  },
] as const;

const kontaktMarkdown =
  "<p>For questions regarding tickets, event bookings or general information, please contact: <a href=\"mailto:info@tadaa.se\">info@tadaa.se</a></p>";

const pressMarkdown = [
  "<h3>Press</h3>",
  "<p><strong>Press Contact</strong><br />Gustaf Tadaa<br />0709-854979<br />gustaf (a) tadaa.se</p>",
  '<p><a href="https://andetag.museum/presskit" target="_blank" rel="noreferrer noopener">Link to press kit</a></p>',
].join("");

const contentsamarbetenMarkdown = [
  "<h3>Content collaborations</h3>",
  "<p>Are you a content creator, photographer, or influencer looking for a unique and luminous backdrop for your work? We&#8217;d love to collaborate!</p>",
  "<p>Our space is a haven of glowing art, stillness, and inspiration – perfect for capturing truly one-of-a-kind content.</p>",
  '<p>Send an email to <a href="mailto:info@tadaa.se">info@tadaa.se</a> for inquiries.</p>',
  "<p>Let&#8217;s create something magical together.</p>",
].join("");

const mapSrc =
  "https://maps.google.com/maps?q=Andetag%2C%20Kungsgatan%2039%2C%20111%2056%20Stockholm&t=m&z=15&output=embed&iwloc=near";

const mapLocationMarkdown =
  "<p>You&#8217;ll find <span class=\"brand-wordmark\">ANDETAG</span> in the central mezzanine of the Hötorget Subway Station.</p><p><strong>From the subway:</strong> Take the Kungsgatan escalator (middle of the platform), then the Kungsgatan exit towards Stureplan, and Sveavägen towards Sergels Torg.</p><p><strong>From the street:</strong> Just below the stairs of the subway entrance on Kungsgatan 39.</p>";

const vimeoSrc = "https://player.vimeo.com/video/1077937338";
---

<div class="page-migrated page-stockholm-home">
  <section
    class="content-section align-center page-stockholm-home__lead-eyebrow page-stockholm-home__lead-eyebrow--page-title"
    aria-label="Introduction"
  >
    <h1>The Breathing Art Museum in Stockholm</h1>
  </section>
  <div class="page-layout-with-aside page-stockholm-home__intro-booking">
    <div class="page-layout-with-aside__main">
      <ContentSection markdown={introMarkdown} />
      <figure class="page-stockholm-home__intro-figure">
        <ResponsiveInlinePicture
          sources={andrumLookingBody}
          width={introLeadImage.width}
          height={introLeadImage.height}
          alt={introLeadImage.alt}
        />
      </figure>
      <AccordionSection items={[...homeAccordionItems]} initialOpenIndex={null} />
      <div class="page-stockholm-home__loc-mobile" aria-label="Address">
        <p class="page-stockholm-home__loc-mobile-text">
          <span class="brand-wordmark">ANDETAG</span><br />
          Kungsgatan 39, Hötorget subway,<br /> Stockholm
        </p>
        <div class="page-stockholm-home__hitta-row">
          <StyledLink label="Getting here" href="#hitta" styleVariant="cta-primary" />
        </div>
      </div>
    </div>
    <aside class="page-layout-with-aside__aside" aria-label="Booking">
      <BookingEmbed
        companyId={understoryCompanyId}
        language="en"
        anchorId="book"
        heading="Book now"
        unframed
        fallbackText="The booking calendar could not load. Reload the page or contact us if the problem persists."
      />
    </aside>
  </div>

  <div class="page-stockholm-home__loc-desktop" aria-label="Address">
    <p class="page-stockholm-home__loc-desktop-text">
      <span class="brand-wordmark">ANDETAG-</span>Kungsgatan 39, Hötorget subway, Stockholm
    </p>
    <div class="page-stockholm-home__hitta-row">
      <StyledLink label="Getting here" href="#hitta" styleVariant="cta-primary" />
    </div>
  </div>

  <GallerySection
    images={[...stockholmMarketingGalleryHome]}
    mobileMode="carousel"
    galleryId="stockholm-home-en"
    carouselAriaLabel="Image gallery"
    galleryNavLocale="en"
  />

  <div class="page-stockholm-home__tickets-columns">
    <div class="page-stockholm-home__tickets-col">
      <ContentSection heading="Tickets" headingLevel="h2" markdown={biljetterIntroHtml} />
      <InfoFrame heading="Pricing" headingLevel="h3" bodyHtml={homePriceFrameHtml} />
    </div>
    <div class="page-stockholm-home__tickets-col">
      <ContentSection heading="Season Pass" headingLevel="h2" markdown={seasonMarkdown} />
      <ContentSection heading="Private experience" headingLevel="h2" markdown={privatMarkdown} />
    </div>
  </div>

  <HeroSection
    backgroundImage={STOCKHOLM_BOOK_HERO_COVER}
    ariaLabel="Take a breath, book a ticket"
    ctas={[{ label: "Book now", href: "#book", variant: "outline" }]}
  >
    <h2 class="page-stockholm-home__book-hero-heading">
      <span class="page-stockholm-home__book-hero-heading-full">Take a Breath – Book your ticket</span>
      <span class="page-stockholm-home__book-hero-heading-short">Take a breath</span>
    </h2>
  </HeroSection>

  <div class="page-layout-with-aside page-stockholm-home__art-yoga">
    <div class="page-layout-with-aside__main">
      <ContentSection heading="Art Yoga - Every Tuesday at 17.00" headingLevel="h2" markdown={artYogaMarkdown} />
      <div class="page-stockholm-home__art-yoga-cta">
        <ButtonGroup
          buttons={[{ label: "Book Yoga", href: artYogaBookingHref, variant: "primary", external: true }]}
        />
      </div>
    </div>
    <aside class="page-layout-with-aside__aside" aria-label="Art Yoga, photo">
      <figure class="page-stockholm-home__art-yoga-figure">
        <ResponsiveInlinePicture
          sources={andrumMeditationBody}
          width={artYogaAsideImage.width}
          height={artYogaAsideImage.height}
          alt={artYogaAsideImage.alt}
          sizes="(max-width: 900px) 100vw, min(42vw, 520px)"
        />
      </figure>
    </aside>
  </div>

  <TestimonialCarousel items={[...testimonialItems]} aggregate={{ ...stockholmTestimonialAggregateEn }} />

  <div class="page-migrated-cta page-stockholm-home__cta-after-testimonials">
    <ButtonGroup buttons={[{ label: "Experience Andetag!", href: "#book", variant: "secondary" }]} />
  </div>

  <div class="page-stockholm-home__video-band">
    <VideoEmbed
      title="ANDETAG on Vimeo"
      src={vimeoSrc}
      fallbackText="The video could not load. Please try again later."
      posterWebp="/assets/video/vimeo-poster-1077937338.webp"
      posterJpeg="/assets/video/vimeo-poster-1077937338.jpg"
    />
  </div>

  <PartnersSection heading="Our partners" headingLevel="h3" partners={[...partners]} />

  <ContentSection heading="Contact" headingLevel="h3" markdown={kontaktMarkdown} />

  <div class="page-stockholm-home__press-grid">
    <ContentSection markdown={pressMarkdown} />
    <ContentSection markdown={contentsamarbetenMarkdown} />
  </div>

  <div class="page-stockholm-home__cta-secondary-band">
    <div class="page-migrated-cta">
      <ButtonGroup buttons={[{ label: "Book tickets now!", href: "#book", variant: "secondary" }]} />
    </div>
  </div>

  <section
    class="content-section page-stockholm-home__map"
    id="hitta"
    aria-labelledby="stockholm-home-map-heading-en"
  >
    <h2 id="stockholm-home-map-heading-en">Where is ANDETAG?</h2>
    <div class="page-stockholm-home__map-grid">
      <div class="content-section-body page-stockholm-home__map-copy" set:html={mapLocationMarkdown} />
      <div class="page-stockholm-home__map-frame">
        <MapEmbed
          title="Andetag, Kungsgatan 39, 111 56 Stockholm"
          src={mapSrc}
          unframed
          fallbackText="The map could not load. Search for Andetag, Kungsgatan 39 in your maps app."
        />
      </div>
    </div>
  </section>
</div>
