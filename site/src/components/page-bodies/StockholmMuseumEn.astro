---
import StockholmSeoLandingEn from "./StockholmSeoLandingEn.astro";

/** English peer of `StockholmMuseumSv.astro`; Swedish source `stockholm-museum-stockholm.html`. */
const introMarkdown = [
  "<p><span class=\"brand-wordmark\">ANDETAG</span> is a small art museum in central Stockholm, near Hötorget. A museum of light, breath, and presence.</p>",
  "<p>There is no traditional collection on the walls. There is a place to pause, sit down, take your time, and land. An immersive art environment where light and woven textile surround the room rather than hang on a wall.<br />Light and textile art woven together with music that shares one breath.</p>",
  "<p>A place to pause.<br />A place to breathe.</p>",
].join("");
---

<StockholmSeoLandingEn
  galleryId="stockholm-en-museum"
  h1Text="A calm museum in Stockholm"
  introMarkdown={introMarkdown}
/>
