---
import AccordionSection from "../content/AccordionSection.astro";
import ContentSection from "../content/ContentSection.astro";
import InfoFrame from "../content/InfoFrame.astro";

/** `site-html/en-stockholm-opening-hours.html` wp-page. */
const hoursHtml =
  "<p><b>Monday: </b>Closed</p>" +
  "<p><b>Tuesday: </b>12.00 – 20.00</p>" +
  "<p><b>Wednesday: </b>12.00 – 20.00</p>" +
  "<p><b>Thursday: </b>12.00 – 20.00</p>" +
  "<p><b>Friday: </b>12.00 – 20.00</p>" +
  "<p><b>Saturday: </b>12.00 – 20.00</p>" +
  "<p><b>Sunday:</b> 12.00 – 17.00</p>" +
  "<p>For holiday opening hours, see our booking calendar.</p>" +
  "<p>Daytime pricing: weekdays 12.00 – 17.00</p>";

const introMarkdown =
  "<p>To maintain a calm flow of visitors, <span class=\"brand-wordmark\">ANDETAG</span> in Stockholm follows fixed start times. From there, you move through the exhibition at your own pace.</p>" +
  "<p>You are welcome to arrive before your scheduled time, as long as regular opening hours apply. Visitors typically stay around 45 minutes, but you are welcome to <strong>stay for as long as you wish.</strong></p>" +
  "<p>Timed booking is used to ensure that too many people do not arrive at once. It is also possible to purchase tickets at the door.</p>";

const accordionItems = [
  {
    title: "How early can I arrive?",
    bodyHtml:
      "<p>You are welcome to arrive a little before your time, as long as regular opening hours apply. Many people like to settle in for a moment first.</p>",
  },
  {
    title: "What happens if I am late?",
    bodyHtml:
      "<p>Do not worry. We always do our best to ensure that everyone can experience <span class=\"brand-wordmark\">ANDETAG</span> at their own pace.</p>",
  },
];
---

<div class="page-migrated page-oppettider-sv">
  <div class="page-oppettider-sv__top">
    <div class="page-oppettider-sv__hours">
      <InfoFrame bodyHtml={hoursHtml} />
    </div>
    <div class="page-oppettider-sv__main">
      <ContentSection heading="Opening hours" headingLevel="h2" markdown={introMarkdown} />
      <AccordionSection items={accordionItems} initialOpenIndex={0} />
    </div>
  </div>
</div>
