---
import ContentSection from "../content/ContentSection.astro";
import MapEmbed from "../embeds/MapEmbed.astro";

/** `site-html/stockholm-hitta-hit.html` wp-page **2826**. */
const mapSrc =
  "https://maps.google.com/maps?q=Andetag%2C%20Kungsgatan%2039%2C%20111%2056%20Stockholm&t=m&z=15&output=embed&iwloc=near";

const directionsMarkdown = [
  "<h3>Mitt i staden. Precis under ytan.</h3>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> ligger i den centrala uppgången av <strong>Hötorgets tunnelbanestation</strong>, mitt i Stockholm. Ett steg ner från stadens tempo.</p>",
  "<h4>Från tunnelbanan</h4>",
  "<p>Ta tunnelbanan till <strong>Hötorget</strong>.</p>",
  "<p>Gå av i mitten av plattformen och följ skyltarna mot <strong>uppgång Kungsgatan</strong>.</p>",
  "<p>Fortsätt mot <strong>Stureplan / Sveavägen mot Sergels torg</strong>.</p>",
  "<p><span class=\"brand-wordmark\">ANDETAG</span> ligger direkt i anslutning till uppgången.</p>",
  "<h4>Från gatan</h4>",
  "<p>Ingången ligger <strong>precis nedanför trappan</strong> till tunnelbanan på <strong>Kungsgatan 39, Stockholm</strong></p>",
  "<h3>Tillgänglighet</h3>",
  "<p>Hiss finns tillgängligt både från tunnelbanans plattform och vid trappan på Kungsgatan 39. Upplevelsen är rullstolsanpassad.</p>",
  '<p><a href="/sv/stockholm/tillganglighet/">Läs mer om tillgänglighet på <span class="brand-wordmark">ANDETAG</span></a></p>',
].join("");
---

<div class="page-migrated page-hitta-hit-sv">
  <div class="page-hitta-hit-sv__grid">
    <div class="page-hitta-hit-sv__title-cell">
      <section class="content-section align-left page-hitta-hit-sv__title-section" aria-labelledby="hitta-hit-h1">
        <h1 id="hitta-hit-h1">
          Hitta till <span class="brand-wordmark">ANDETAG</span>
        </h1>
      </section>
    </div>
    <div class="page-hitta-hit-sv__body-cell">
      <ContentSection markdown={directionsMarkdown} />
    </div>
    <div class="page-hitta-hit-sv__map-cell">
      <div class="page-hitta-hit-sv__map-frame">
        <MapEmbed
          title="Andetag, Kungsgatan 39, 111 56 Stockholm"
          src={mapSrc}
          unframed
          fallbackText="Kartan kunde inte laddas. Sök på Andetag, Kungsgatan 39 i din kartapp."
        />
      </div>
    </div>
  </div>
  <p class="page-hitta-hit-sv__footer-line content-section align-center" aria-label="Adress">
    <span class="brand-wordmark">ANDETAG-</span>Kungsgatan 39, Hötorgets tunnelbana, Stockholm
  </p>
</div>
