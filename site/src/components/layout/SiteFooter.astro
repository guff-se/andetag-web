---
import type { PageLayoutModel } from "../../lib/layout/page-layout";
import { getSwedishFooterModel } from "../../lib/layout/footer-sv";
const { model } = Astro.props as { model: PageLayoutModel };
const swedishFooter = model.footer.id === "footer-207" ? getSwedishFooterModel() : null;
---

{
  swedishFooter ? (
    <footer class="shared-footer-root">
      <div class="shared-footer-container">
        <div class="shared-footer-grid">
          <section class="shared-footer-col">
            <p>{swedishFooter.sections[0]?.title}</p>
            <ul>
              {swedishFooter.sections[0]?.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
            </ul>
          </section>
          <section class="shared-footer-col">
            <p>{swedishFooter.sections[1]?.title}</p>
            <ul>
              {swedishFooter.sections[1]?.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
            </ul>
          </section>
          <section class="shared-footer-col">
            <p>{swedishFooter.groupedSections[0]?.title}</p>
            <ul>
              {swedishFooter.groupedSections[0]?.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
            </ul>
            <p>{swedishFooter.groupedSections[1]?.title}</p>
            <ul>
              {swedishFooter.groupedSections[1]?.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
            </ul>
          </section>
        </div>

        <p class="shared-footer-seo-links">
          {
            swedishFooter.seoLinks.map((link, index) => (
              <span>
                {index > 0 && <span> / </span>}
                <a href={link.href}>{link.label}</a>
              </span>
            ))
          }
        </p>

        <div class="shared-footer-bottom">
          <div class="shared-footer-copyright">{swedishFooter.copyright}</div>
          <div class="shared-footer-privacy"><a href={swedishFooter.privacyLink.href}>{swedishFooter.privacyLink.label}</a></div>
          <div class="shared-footer-socials" aria-label="Social links">
            {
              swedishFooter.socialLinks.map((link) => (
                <a href={link.href} aria-label={link.label} rel={link.href.startsWith("http") ? "noreferrer" : undefined} target={link.href.startsWith("http") ? "_blank" : undefined}>
                  {
                    link.icon === "instagram" ? (
                      <svg viewBox="0 0 448 512" aria-hidden="true"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
                    ) : link.icon === "facebook" ? (
                      <svg viewBox="0 0 320 512" aria-hidden="true"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
                    ) : link.icon === "pinterest" ? (
                      <svg viewBox="0 0 496 512" aria-hidden="true"><path d="M496 256c0 137-111 248-248 248-25.6 0-50.2-3.9-73.4-11.1 10.1-16.5 25.2-43.5 30.8-65 3-11.6 15.4-59 15.4-59 8.1 15.4 31.7 28.5 56.8 28.5 74.8 0 128.7-68.8 128.7-154.3 0-81.9-66.9-143.2-152.9-143.2-107 0-163.9 71.8-163.9 150.1 0 36.4 19.4 81.7 50.3 96.1 4.7 2.2 7.2 1.2 8.3-3.3.8-3.4 5-20.3 6.9-28.1.6-2.5.3-4.7-1.7-7.1-10.1-12.5-18.3-35.3-18.3-56.6 0-54.7 41.4-107.6 112-107.6 60.9 0 103.6 41.5 103.6 100.9 0 67.1-33.9 113.6-78 113.6-24.3 0-42.6-20.1-36.7-44.8 7-29.5 20.5-61.3 20.5-82.6 0-19-10.2-34.9-31.4-34.9-24.9 0-44.9 25.7-44.9 60.2 0 22 7.4 36.8 7.4 36.8s-24.5 103.8-29 123.2c-5 21.4-3 51.6-.9 71.2C65.4 450.9 0 361.1 0 256 0 119 111 8 248 8s248 111 248 248z"/></svg>
                    ) : (
                      <svg viewBox="0 0 496 512" aria-hidden="true"><path d="M248 8C111.1 8 0 119.1 0 256s111.1 248 248 248 248-111.1 248-248S384.9 8 248 8zm100.7 364.9c-4.2 0-6.8-1.3-10.7-3.6-62.4-37.6-135-39.2-206.7-24.5-3.9 1-9 2.6-11.9 2.6-9.7 0-15.8-7.7-15.8-15.8 0-10.3 6.1-15.2 13.6-16.8 81.9-18.1 165.6-16.5 237 26.2 6.1 3.9 9.7 7.4 9.7 16.5s-7.1 15.4-15.2 15.4zm26.9-65.6c-5.2 0-8.7-2.3-12.3-4.2-62.5-37-155.7-51.9-238.6-29.4-4.8 1.3-7.4 2.6-11.9 2.6-10.7 0-19.4-8.7-19.4-19.4s5.2-17.8 15.5-20.7c27.8-7.8 56.2-13.6 97.8-13.6 64.9 0 127.6 16.1 177 45.5 8.1 4.8 11.3 11 11.3 19.7-.1 10.8-8.5 19.5-19.4 19.5zm31-76.2c-5.2 0-8.4-1.3-12.9-3.9-71.2-42.5-198.5-52.7-280.9-29.7-3.6 1-8.1 2.6-12.9 2.6-13.2 0-23.3-10.3-23.3-23.6 0-13.6 8.4-21.3 17.4-23.9 35.2-10.3 74.6-15.2 117.5-15.2 73 0 149.5 15.2 205.4 47.8 7.8 4.5 12.9 10.7 12.9 22.6 0 13.6-11 23.3-23.2 23.3z"/></svg>
                    )
                  }
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </footer>
  ) : (
    <footer class="footer-root">
      <div class="footer-container">
        <p class="hero-note">Footer variant: {model.footer.id}</p>
        <div class="footer-links" aria-label="Legal links">
          {
            model.footer.legalLinks.map((link) => (
              <a class="chip" href={link.href}>{link.label}</a>
            ))
          }
        </div>
        <div class="footer-socials" aria-label="Social links">
          {
            model.footer.socialLinks.map((link) => (
              <a class="chip" href={link.href} rel="noreferrer" target="_blank">{link.label}</a>
            ))
          }
        </div>
      </div>
    </footer>
  )
}
