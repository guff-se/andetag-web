---
import AccordionSection from "../components/content/AccordionSection.astro";
import BrandWordmark from "../components/ui/BrandWordmark.astro";
import BookingEmbed from "../components/embeds/BookingEmbed.astro";
import ButtonGroup from "../components/content/ButtonGroup.astro";
import ContentSection from "../components/content/ContentSection.astro";
import GallerySection from "../components/content/GallerySection.astro";
import HeroSection from "../components/content/HeroSection.astro";
import InfoCardGrid from "../components/content/InfoCardGrid.astro";
import MapEmbed from "../components/embeds/MapEmbed.astro";
import PartnersSection from "../components/content/PartnersSection.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import TestimonialCarousel from "../components/content/TestimonialCarousel.astro";
import VideoEmbed from "../components/embeds/VideoEmbed.astro";
import WaitlistFormEmbed from "../components/embeds/WaitlistFormEmbed.astro";
import {
  ACCORDION_ITEMS,
  DEMO_CTAS,
  GALLERY_IMAGES,
  INFO_CARDS,
  PARTNERS,
  TESTIMONIALS,
} from "../data/component-showcase";
import { LAYOUT_EXAMPLES } from "../data/layout-examples";
import StyledLink from "../components/ui/StyledLink.astro";

const base = LAYOUT_EXAMPLES.find((example) => example.id === "sv-home-hero");
if (!base) {
  throw new Error("Missing sv-home-hero layout example");
}
---

<SiteLayout
  title="Component Showcase | ANDETAG"
  language={base.language}
  destination={base.destination}
  headerVariantId={base.headerVariantId}
  footerVariantId={base.footerVariantId}
  canonicalPath="/component-showcase/"
  hreflang={{ sv: null, en: null, de: null }}
  robots="noindex,nofollow"
  fullWidthMain={true}
  bodyClass="theme-pink"
>
  <div class="component-showcase">
    <section>
      <h1>Phase 3 Component Showcase</h1>
      <p>Single review page for all approved components and required states before consolidated sign-off.</p>
      <BrandWordmark as="p" />
    </section>

    <section class="component-demo">
      <h2>Styled Links and Button Group</h2>
      <ButtonGroup buttons={DEMO_CTAS} />
      <p>
        Content link example:
        <StyledLink label="Vanliga frågor" href="/stockholm/fragor-svar/" styleVariant="content" />
      </p>
      <p>
        Footer link example:
        <StyledLink label="Integritetspolicy" href="/privacy/" styleVariant="footer" />
      </p>
    </section>

    <section class="component-demo">
      <h2>Hero Section</h2>
      <HeroSection
        heading="Upplev ANDETAG i Stockholm"
        body="En immersiv ljusupplevelse, musik och stillhet under samma tak."
        eyebrow="Stockholm"
        headingLevel="h2"
        ctas={DEMO_CTAS}
      />
      <HeroSection
        heading="Take a Breath - Book your ticket"
        headingLevel="h2"
        ctas={[{ label: "Book now", href: "/stockholm/biljetter/", variant: "outline" }]}
        backgroundImage="/wp-content/uploads/2024/11/Andetag-21-399-scaled.jpg"
      />
    </section>

    <section class="component-demo">
      <h2>Content and Accordion</h2>
      <ContentSection
        heading="Innehållssektion med länkar"
        headingLevel="h2"
        markdown="<p>Detta är en bassektion med text och <a href='/en/stockholm/faq/'>intern länk</a>.</p>"
      />
      <ContentSection markdown="<p>Body-only variant utan rubrik.</p>" />
      <AccordionSection items={ACCORDION_ITEMS} />
    </section>

    <section class="component-demo">
      <h2>Gallery and Partners</h2>
      <GallerySection images={GALLERY_IMAGES} mobileMode="carousel" />
      <PartnersSection heading="Våra partners" headingLevel="h3" partners={PARTNERS} />
    </section>

    <section class="component-demo">
      <h2>Testimonials and Cards</h2>
      <TestimonialCarousel
        items={TESTIMONIALS}
        backgroundImage="/wp-content/uploads/2024/11/Andetag-27-037-copy-scaled.jpg"
      />
      <InfoCardGrid cards={INFO_CARDS} />
    </section>

    <section class="component-demo">
      <h2>Embeds and Fallback States</h2>
      <h3>Booking</h3>
      <BookingEmbed
        companyId="andetag"
        language="sv"
        fallbackText="Bokningswidgeten är tillfälligt otillgänglig."
      />
      <BookingEmbed
        companyId="andetag"
        language="sv"
        fallbackText="Bokningswidgeten är tillfälligt otillgänglig."
        unavailable={true}
      />

      <h3>Waitlist</h3>
      <WaitlistFormEmbed formId="brevo-demo" locale="de" fallbackText="Formuläret är tillfälligt otillgängligt." />
      <WaitlistFormEmbed
        formId="brevo-demo"
        locale="de"
        fallbackText="Formuläret är tillfälligt otillgängligt."
        unavailable={true}
      />

      <h3>Map</h3>
      <MapEmbed
        title="ANDETAG map demo"
        src="https://maps.google.com/maps?q=Stockholm&t=&z=13&ie=UTF8&iwloc=&output=embed"
        fallbackText="Kartan kräver samtycke eller är tillfälligt otillgänglig."
      />
      <MapEmbed
        title="ANDETAG map demo"
        src="https://maps.google.com/maps?q=Stockholm&t=&z=13&ie=UTF8&iwloc=&output=embed"
        fallbackText="Kartan kräver samtycke eller är tillfälligt otillgänglig."
        unavailable={true}
      />

      <h3>Video</h3>
      <VideoEmbed
        title="ANDETAG video demo"
        src="https://player.vimeo.com/video/1077937338"
        fallbackText="Videon kräver samtycke eller är tillfälligt otillgänglig."
      />
      <VideoEmbed
        title="ANDETAG video demo"
        src="https://player.vimeo.com/video/1077937338"
        fallbackText="Videon kräver samtycke eller är tillfälligt otillgänglig."
        unavailable={true}
      />
    </section>
  </div>
</SiteLayout>
