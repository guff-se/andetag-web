---
import SiteLayout from "../layouts/SiteLayout.astro";
import ArtYogaEn from "../components/page-bodies/ArtYogaEn.astro";
import ArtYogaSv from "../components/page-bodies/ArtYogaSv.astro";
import ArtworksEn from "../components/page-bodies/ArtworksEn.astro";
import KonstverkSv from "../components/page-bodies/KonstverkSv.astro";
import BesokaromdomenEn from "../components/page-bodies/BesokaromdomenEn.astro";
import BesokaromdomenSv from "../components/page-bodies/BesokaromdomenSv.astro";
import BiljetterEn from "../components/page-bodies/BiljetterEn.astro";
import BiljetterSv from "../components/page-bodies/BiljetterSv.astro";
import DejtEn from "../components/page-bodies/DejtEn.astro";
import DejtSv from "../components/page-bodies/DejtSv.astro";
import ForetagseventEn from "../components/page-bodies/ForetagseventEn.astro";
import ForetagseventSv from "../components/page-bodies/ForetagseventSv.astro";
import FragorSvarEn from "../components/page-bodies/FragorSvarEn.astro";
import FragorSvarSv from "../components/page-bodies/FragorSvarSv.astro";
import GruppbokningEn from "../components/page-bodies/GruppbokningEn.astro";
import GruppbokningSv from "../components/page-bodies/GruppbokningSv.astro";
import HittaHitEn from "../components/page-bodies/HittaHitEn.astro";
import HittaHitSv from "../components/page-bodies/HittaHitSv.astro";
import MusikEn from "../components/page-bodies/MusikEn.astro";
import MusikSv from "../components/page-bodies/MusikSv.astro";
import NpfStockholmEn from "../components/page-bodies/NpfStockholmEn.astro";
import NpfStockholmSv from "../components/page-bodies/NpfStockholmSv.astro";
import OmAndetagEn from "../components/page-bodies/OmAndetagEn.astro";
import OmAndetagSv from "../components/page-bodies/OmAndetagSv.astro";
import OmKonstnarernaEn from "../components/page-bodies/OmKonstnarernaEn.astro";
import OmKonstnarernaSv from "../components/page-bodies/OmKonstnarernaSv.astro";
import OppettiderEn from "../components/page-bodies/OppettiderEn.astro";
import OppettiderSv from "../components/page-bodies/OppettiderSv.astro";
import OpticalFibreTextileEn from "../components/page-bodies/OpticalFibreTextileEn.astro";
import OptiskFibertextilSv from "../components/page-bodies/OptiskFibertextilSv.astro";
import PresentkortEn from "../components/page-bodies/PresentkortEn.astro";
import PresentkortSv from "../components/page-bodies/PresentkortSv.astro";
import SasongskortEn from "../components/page-bodies/SasongskortEn.astro";
import SasongskortSv from "../components/page-bodies/SasongskortSv.astro";
import StockholmAktivitetInomhusSv from "../components/page-bodies/StockholmAktivitetInomhusSv.astro";
import StockholmAttGoraSv from "../components/page-bodies/StockholmAttGoraSv.astro";
import StockholmExhibitionEn from "../components/page-bodies/StockholmExhibitionEn.astro";
import BerlinHomeEn from "../components/page-bodies/BerlinHomeEn.astro";
import BerlinHomeDe from "../components/page-bodies/BerlinHomeDe.astro";
import DieKuenstlerDe from "../components/page-bodies/DieKuenstlerDe.astro";
import MusikVonAndetagDe from "../components/page-bodies/MusikVonAndetagDe.astro";
import OptischeFasertextilDe from "../components/page-bodies/OptischeFasertextilDe.astro";
import UeberAndetagDe from "../components/page-bodies/UeberAndetagDe.astro";
import StockholmHomeEn from "../components/page-bodies/StockholmHomeEn.astro";
import StockholmHomeSv from "../components/page-bodies/StockholmHomeSv.astro";
import StockholmIndoorActivityEn from "../components/page-bodies/StockholmIndoorActivityEn.astro";
import StockholmMeditationEn from "../components/page-bodies/StockholmMeditationEn.astro";
import StockholmMeditationSv from "../components/page-bodies/StockholmMeditationSv.astro";
import StockholmMuseumEn from "../components/page-bodies/StockholmMuseumEn.astro";
import StockholmMuseumSv from "../components/page-bodies/StockholmMuseumSv.astro";
import StockholmEventStockholmEn from "../components/page-bodies/StockholmEventStockholmEn.astro";
import StockholmEventStockholmSv from "../components/page-bodies/StockholmEventStockholmSv.astro";
import StockholmThingsToDoEn from "../components/page-bodies/StockholmThingsToDoEn.astro";
import StockholmUtstallningSv from "../components/page-bodies/StockholmUtstallningSv.astro";
import TillganglighetEn from "../components/page-bodies/TillganglighetEn.astro";
import TillganglighetSv from "../components/page-bodies/TillganglighetSv.astro";
import VilkenTypAvUpplevelseEn from "../components/page-bodies/VilkenTypAvUpplevelseEn.astro";
import PrivacyPage from "../components/page-bodies/PrivacyPage.astro";
import VilkenTypAvUpplevelseSv from "../components/page-bodies/VilkenTypAvUpplevelseSv.astro";
import { HEADER_SMALL_LCP_PRELOAD_WEBP, HERO_SV_ASSETS } from "../lib/chrome/assets";
import {
  getPageShellRoute,
  PAGE_SHELL_PATHS,
  slugParamForShellPath,
} from "../lib/routes/page-shell-registry";

export function getStaticPaths() {
  return PAGE_SHELL_PATHS.map((canonicalPath) => ({
    params: { slug: slugParamForShellPath(canonicalPath) },
  }));
}

const slug = Astro.params.slug as string;
const segments = slug.split("/").filter(Boolean);
const canonicalPath = `/${segments.join("/")}/`;
const shell = getPageShellRoute(canonicalPath);

type ShellPageBody = typeof MusikSv;

/** Keep keys aligned with `PAGE_CUSTOM_BODY_PATHS` in `lib/page-registry/page-body-registry.ts`. */
const pageBodies: Partial<Record<string, ShellPageBody>> = {
  "/en/stockholm/about-andetag/": OmAndetagEn,
  "/en/stockholm/about-the-artists-malin-gustaf-tadaa/": OmKonstnarernaEn,
  "/en/stockholm/music/": MusikEn,
  "/en/stockholm/optical-fibre-textile/": OpticalFibreTextileEn,
  "/en/berlin/about-andetag/": OmAndetagEn,
  "/en/berlin/about-the-artists-malin-gustaf-tadaa/": OmKonstnarernaEn,
  "/en/berlin/music/": MusikEn,
  "/en/berlin/optical-fibre-textile/": OpticalFibreTextileEn,
  "/en/berlin/": BerlinHomeEn,
  "/de/berlin/": BerlinHomeDe,
  "/de/berlin/ueber-andetag/": UeberAndetagDe,
  "/de/berlin/musik-von-andetag/": MusikVonAndetagDe,
  "/de/berlin/optische-fasertextil/": OptischeFasertextilDe,
  "/de/berlin/die-kuenstler-malin-gustaf-tadaa/": DieKuenstlerDe,
  "/en/stockholm/": StockholmHomeEn,
  "/en/stockholm/accessibility/": TillganglighetEn,
  "/en/stockholm/art-yoga/": ArtYogaEn,
  "/en/stockholm/artworks/": ArtworksEn,
  "/en/stockholm/corporate-events/": ForetagseventEn,
  "/en/stockholm/date/": DejtEn,
  "/en/stockholm/exhibition-stockholm/": StockholmExhibitionEn,
  "/en/stockholm/faq/": FragorSvarEn,
  "/en/stockholm/giftcard/": PresentkortEn,
  "/en/stockholm/group-bookings/": GruppbokningEn,
  "/en/stockholm/how-to-find-us/": HittaHitEn,
  "/en/stockholm/indoor-activity-stockholm/": StockholmIndoorActivityEn,
  "/en/stockholm/meditation-stockholm/": StockholmMeditationEn,
  "/en/stockholm/museum-stockholm/": StockholmMuseumEn,
  "/en/stockholm/neurodivergent-art/": NpfStockholmEn,
  "/en/stockholm/opening-hours/": OppettiderEn,
  "/en/stockholm/season-pass/": SasongskortEn,
  "/en/stockholm/tickets/": BiljetterEn,
  "/en/stockholm/event-stockholm/": StockholmEventStockholmEn,
  "/en/stockholm/things-to-do-stockholm/": StockholmThingsToDoEn,
  "/en/stockholm/visitor-reviews/": BesokaromdomenEn,
  "/en/stockholm/what-kind-of-experience/": VilkenTypAvUpplevelseEn,
  "/sv/stockholm/musik/": MusikSv,
  "/sv/stockholm/om-andetag/": OmAndetagSv,
  "/sv/stockholm/om-konstnarerna-malin-gustaf-tadaa/": OmKonstnarernaSv,
  "/sv/stockholm/optisk-fibertextil/": OptiskFibertextilSv,
  "/sv/stockholm/privacy/": PrivacyPage,
  "/en/stockholm/privacy/": PrivacyPage,
  "/de/berlin/privacy/": PrivacyPage,
  "/en/berlin/privacy/": PrivacyPage,
  "/sv/stockholm/": StockholmHomeSv,
  "/sv/stockholm/aktivitet-inomhus-stockholm/": StockholmAktivitetInomhusSv,
  "/sv/stockholm/art-yoga/": ArtYogaSv,
  "/sv/stockholm/att-gora-stockholm/": StockholmAttGoraSv,
  "/sv/stockholm/event-stockholm/": StockholmEventStockholmSv,
  "/sv/stockholm/meditation-stockholm/": StockholmMeditationSv,
  "/sv/stockholm/besokaromdomen/": BesokaromdomenSv,
  "/sv/stockholm/biljetter/": BiljetterSv,
  "/sv/stockholm/dejt/": DejtSv,
  "/sv/stockholm/foretagsevent/": ForetagseventSv,
  "/sv/stockholm/fragor-svar/": FragorSvarSv,
  "/sv/stockholm/gruppbokning/": GruppbokningSv,
  "/sv/stockholm/hitta-hit/": HittaHitSv,
  "/sv/stockholm/konstverk/": KonstverkSv,
  "/sv/stockholm/museum-stockholm/": StockholmMuseumSv,
  "/sv/stockholm/npf-stockholm/": NpfStockholmSv,
  "/sv/stockholm/oppettider/": OppettiderSv,
  "/sv/stockholm/presentkort/": PresentkortSv,
  "/sv/stockholm/sasongskort/": SasongskortSv,
  "/sv/stockholm/tillganglighet/": TillganglighetSv,
  "/sv/stockholm/utstallning-stockholm/": StockholmUtstallningSv,
  "/sv/stockholm/vilken-typ-av-upplevelse/": VilkenTypAvUpplevelseSv,
};
const PageBody = pageBodies[canonicalPath];
if (!PageBody && canonicalPath !== "/en/") {
  throw new Error(`No page body component for path: ${canonicalPath}`);
}
const headerSelectorOnly = canonicalPath === "/en/";
const robots = canonicalPath === "/en/" ? "noindex,follow" : undefined;
const includeStructuredData = canonicalPath !== "/en/";

/** Full-bleed video hero (`SiteHeader.astro`): preload poster + Jost 500 for earlier paint (all breakpoints use video). */
const heroVideoHeaderIds = new Set<typeof shell.headerVariantId>([
  "chrome-hdr-sv-stockholm-hero",
  "chrome-hdr-en-stockholm-hero",
  "chrome-hdr-en-header-selector",
  "chrome-hdr-en-berlin-hero",
  "chrome-hdr-de-berlin-hero",
]);
/** Static-image small hero: responsive stack in `SiteHeader.astro`; mobile WebP preload for LCP (PageSpeed mobile). */
const smallHeroHeaderIds = new Set<typeof shell.headerVariantId>([
  "chrome-hdr-sv-stockholm-small",
  "chrome-hdr-en-stockholm-small",
  "chrome-hdr-en-berlin-small",
  "chrome-hdr-de-berlin-small",
]);
/** Video hero `<picture>` lists AVIF before WebP; preloading WebP while Chrome picks AVIF wasted fetch and delayed LCP. */
const lcpImagePreloads = heroVideoHeaderIds.has(shell.headerVariantId)
  ? ([
      {
        href: HERO_SV_ASSETS.posterAvif960,
        media: "(max-width: 900px)",
        type: "image/avif",
      },
      {
        href: HERO_SV_ASSETS.posterAvif1920,
        media: "(min-width: 901px)",
        type: "image/avif",
      },
    ] as const)
  : null;
const lcpImagePreloadHref = heroVideoHeaderIds.has(shell.headerVariantId)
  ? null
  : smallHeroHeaderIds.has(shell.headerVariantId)
    ? HEADER_SMALL_LCP_PRELOAD_WEBP
    : null;
const lcpImagePreloadMedia = smallHeroHeaderIds.has(shell.headerVariantId)
  ? "(max-width: 767px)"
  : null;
const lcpFontPreloadHref =
  heroVideoHeaderIds.has(shell.headerVariantId) || smallHeroHeaderIds.has(shell.headerVariantId)
    ? "/fonts/jost/jost-500-normal-latin.woff2"
    : null;

/** Text-heavy shells: small header + Baskervville body often wins LCP; preload Latin 400. */
const LCP_BODY_FONT_PRELOAD_HREF = "/fonts/baskervville/baskervville-400-normal-latin.woff2";
const LCP_BODY_FONT_PATHS = new Set<string>([
  "/en/stockholm/privacy/",
  "/sv/stockholm/privacy/",
  "/en/berlin/privacy/",
  "/de/berlin/privacy/",
  "/sv/stockholm/musik/",
  "/en/stockholm/music/",
  "/en/berlin/music/",
  "/de/berlin/musik-von-andetag/",
  "/sv/stockholm/foretagsevent/",
  "/en/stockholm/corporate-events/",
  "/sv/stockholm/besokaromdomen/",
  "/en/stockholm/visitor-reviews/",
]);
const lcpBodyFontPreloadHref = LCP_BODY_FONT_PATHS.has(canonicalPath)
  ? LCP_BODY_FONT_PRELOAD_HREF
  : null;
---

<SiteLayout
  title={shell.title}
  description={shell.description}
  language={shell.language}
  destination={shell.destination}
  headerVariantId={shell.headerVariantId}
  footerVariantId={shell.footerVariantId}
  canonicalPath={shell.canonicalPath}
  seoCanonicalPath={shell.seoCanonicalPath}
  hreflang={shell.hreflang}
  xDefaultPath={shell.xDefaultPath}
  lcpImagePreloadHref={lcpImagePreloadHref}
  lcpImagePreloadMedia={lcpImagePreloadMedia}
  lcpImagePreloads={lcpImagePreloads}
  lcpFontPreloadHref={lcpFontPreloadHref}
  lcpBodyFontPreloadHref={lcpBodyFontPreloadHref}
  headerSelectorOnly={headerSelectorOnly}
  ogImagePublicPath={shell.ogImage}
  robots={robots}
  includeStructuredData={includeStructuredData}
>
  {
    headerSelectorOnly ? null : PageBody === PrivacyPage ? (
      <PrivacyPage language={shell.language} />
    ) : PageBody ? (
      <PageBody />
    ) : (
      <div class="page-shell-placeholder" aria-hidden="true"></div>
    )
  }
</SiteLayout>
