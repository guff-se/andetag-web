---
import { createPageLayoutModel } from "../lib/layout/page-layout";
import { LAYOUT_EXAMPLES } from "../data/layout-examples";
import "../styles/layout.css";

const cards = LAYOUT_EXAMPLES.map((example) => ({
  example,
  model: createPageLayoutModel(example),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Layout Preview | Phase 2</title>
  </head>
  <body>
    <main class="main-content">
      <h1>Phase 2 Layout Preview</h1>
      <p>
        Snapshot page for desktop/tablet and mobile layout review, including header/footer variants,
        separate language and destination selectors, and link parity checks.
      </p>
      <div class="variant-grid">
        {
          cards.map(({ example, model }) => (
            <section class="variant-card">
              <h2>{example.id}</h2>
              <div class="header-container">
                <p class="hero-note">{example.description}</p>
                <p class="hero-note">Header variant: {model.header.id}</p>
                <p class="hero-note">Footer variant: {model.footer.id}</p>
                <p class="hero-note">Desktop/tablet nav: {model.navigation.id}</p>
                <p class="hero-note">Mobile nav: {model.navigationMobile.id}</p>
                <div class="selectors">
                  {model.destinationSelector.map((option) => <span class="chip">{option.label}</span>)}
                </div>
                <div class="selectors">
                  {model.languageSelector.map((option) => <span class="chip">{option.label}</span>)}
                </div>
                <ul class="nav-list">
                  {model.navigation.items.map((item) => <li><a class="chip" href={item.href}>{item.label}</a></li>)}
                </ul>
                <ul class="footer-links">
                  {model.footer.legalLinks.map((link) => <li><a class="chip" href={link.href}>{link.label}</a></li>)}
                </ul>
              </div>
            </section>
          ))
        }
      </div>
    </main>
  </body>
</html>
