---
import SiteFooter from "../components/chrome/SiteFooter.astro";
import SiteHeader from "../components/chrome/SiteHeader.astro";
import TrackingBody from "../components/chrome/TrackingBody.astro";
import TrackingHead from "../components/chrome/TrackingHead.astro";
import { createPageLayoutModel } from "../lib/chrome/page-layout";
import { buildSchemaJsonLd } from "../lib/chrome/schema-org";
import {
  OG_SITE_NAME,
  canonicalUrlForSitePath,
  defaultOgImageAbsoluteUrl,
  languageToOgLocale,
  ogLocaleAlternates,
} from "../lib/chrome/seo";
import type {
  Destination,
  FooterVariantId,
  HeaderVariantId,
  Language,
  LegacyHeaderAliasId,
} from "../lib/chrome/types";
import "../styles/fonts.css";
import "../styles/layout.css";
import "../styles/components.css";
import "../styles/print.css";

type Props = {
  title: string;
  description?: string;
  language: Language;
  destination: Destination;
  headerVariantId: HeaderVariantId | LegacyHeaderAliasId;
  footerVariantId: FooterVariantId;
  canonicalPath: string;
  /** Optional SEO canonical path (Berlin English story pages → Stockholm English). */
  seoCanonicalPath?: string | null;
  hreflang: Record<Language, string | null>;
  xDefaultPath?: string | null;
  robots?: "index,follow" | "noindex,nofollow";
  fullWidthMain?: boolean;
  bodyClass?: string;
  /** When set, emits an early high-priority image preload (LCP: small-header mobile WebP, etc.). */
  lcpImagePreloadHref?: string | null;
  /** Optional `media` on the image preload (for example `(max-width: 767px)` for small-header mobile art direction). */
  lcpImagePreloadMedia?: string | null;
  /**
   * Art-directed LCP preloads (preferred for video hero: must match `<picture>` type order, e.g. AVIF before WebP).
   * When non-empty, overrides `lcpImagePreloadHref` / `lcpImagePreloadMedia`.
   */
  lcpImagePreloads?: readonly { href: string; media?: string | null; type?: string | null }[] | null;
  /** Optional WOFF2 preload for above-the-fold UI using that face (Jost 500 on Swedish video hero). */
  lcpFontPreloadHref?: string | null;
  /** Optional body-serif preload when prose is likely LCP (privacy, long-form text pages with small header). */
  lcpBodyFontPreloadHref?: string | null;
  /** `/en/` hub: only the header-selector hero, no main column or footer. */
  headerSelectorOnly?: boolean;
  /** Root-relative image path for `og:image` / Twitter when set. */
  ogImagePublicPath?: string | null;
  /** Emit JSON-LD (off for `404` and similar). Default true. */
  includeStructuredData?: boolean;
};

const props = Astro.props as Props;
const model = createPageLayoutModel({
  language: props.language,
  destination: props.destination,
  headerVariantId: props.headerVariantId,
  footerVariantId: props.footerVariantId,
  canonicalPath: props.canonicalPath,
  seoCanonicalPath: props.seoCanonicalPath ?? null,
  hreflang: props.hreflang,
  xDefaultPath: props.xDefaultPath ?? null,
});

const ogImageUrl =
  props.ogImagePublicPath && props.ogImagePublicPath.length > 0
    ? canonicalUrlForSitePath(props.ogImagePublicPath)
    : defaultOgImageAbsoluteUrl();
/** Default Stockholm hero JPEG is 1920×1080; helps scrapers (not the LCP `960w` preload). */
const ogImageStockholmHeroExtras =
  ogImageUrl === defaultOgImageAbsoluteUrl() ? ({ w: 1920, h: 1080 } as const) : null;
const ogPrimaryLocale = languageToOgLocale(props.language);
const ogAlternateLocales = ogLocaleAlternates(props.language, props.hreflang);
const includeStructuredData = props.includeStructuredData !== false;
const jsonLd = includeStructuredData
  ? buildSchemaJsonLd({
      pageUrl: model.canonicalUrl,
      pageTitle: props.title,
      pageDescription: props.description ?? "",
      language: props.language,
      destination: props.destination,
      canonicalPath: props.canonicalPath,
    })
  : null;
---

<!doctype html>
<html lang={props.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#4a0d2f" />
    <!-- dns-prefetch for third-party origins (GTM deferred to load). -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <!-- LCP preloads: placed early so the preload scanner discovers them immediately. -->
    {
      props.lcpImagePreloads && props.lcpImagePreloads.length > 0 ? (
        props.lcpImagePreloads.map((entry) => (
          <link
            rel="preload"
            as="image"
            href={entry.href}
            fetchpriority="high"
            {...(entry.media ? { media: entry.media } : {})}
            {...(entry.type ? { type: entry.type } : {})}
          />
        ))
      ) : props.lcpImagePreloadHref ? (
        <link
          rel="preload"
          as="image"
          href={props.lcpImagePreloadHref}
          fetchpriority="high"
          {...(props.lcpImagePreloadMedia ? { media: props.lcpImagePreloadMedia } : {})}
        />
      ) : null
    }
    {
      props.lcpFontPreloadHref ? (
        <link
          rel="preload"
          href={props.lcpFontPreloadHref}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ) : null
    }
    {
      props.lcpBodyFontPreloadHref ? (
        <link
          rel="preload"
          href={props.lcpBodyFontPreloadHref}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ) : null
    }
    <TrackingHead />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{props.title}</title>
    {props.description ? <meta name="description" content={props.description} /> : null}
    {props.robots ? <meta name="robots" content={props.robots} /> : null}
    <link rel="canonical" href={model.canonicalUrl} />
    {
      model.hreflangLinks.map((link) => (
        <link rel="alternate" hreflang={link.hreflang} href={link.href} />
      ))
    }
    <meta property="og:title" content={props.title} />
    {
      props.description ? (
        <meta property="og:description" content={props.description} />
      ) : null
    }
    <meta property="og:url" content={model.canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={OG_SITE_NAME} />
    <meta property="og:locale" content={ogPrimaryLocale} />
    {
      ogAlternateLocales.map((locale) => (
        <meta property="og:locale:alternate" content={locale} />
      ))
    }
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    {
      ogImageStockholmHeroExtras ? (
        <>
          <meta property="og:image:width" content={String(ogImageStockholmHeroExtras.w)} />
          <meta property="og:image:height" content={String(ogImageStockholmHeroExtras.h)} />
          <meta property="og:image:type" content="image/jpeg" />
        </>
      ) : null
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={props.title} />
    {
      props.description ? (
        <meta name="twitter:description" content={props.description} />
      ) : null
    }
    <meta name="twitter:image" content={ogImageUrl} />
    {
      jsonLd ? (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      ) : null
    }
  </head>
  <body
    class={`${props.bodyClass ?? ""}${props.headerSelectorOnly ? " page-en-selector-only" : ""}`.trim()}
  >
    <TrackingBody />
    {
      props.headerSelectorOnly ? (
        <a class="skip-link" href="#en-selector-actions">Skip to location choice</a>
      ) : (
        <a class="skip-link" href="#main-content">
          {props.language === "en"
            ? "Skip to content"
            : props.language === "de"
              ? "Zum Inhalt springen"
              : "Hoppa till innehåll"}
        </a>
      )
    }
    <div class={`page-shell${props.headerSelectorOnly ? " page-shell--en-selector-only" : ""}`.trim()}>
      <SiteHeader model={model} currentPath={Astro.url.pathname} />
      {
        props.headerSelectorOnly ? null : (
          <main
            id="main-content"
            class={`main-content ${props.fullWidthMain ? "main-content-wide" : ""}`.trim()}
            tabindex="-1"
          >
            <slot />
          </main>
        )
      }
      {props.headerSelectorOnly ? null : <SiteFooter model={model} />}
    </div>
  </body>
</html>
