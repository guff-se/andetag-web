# Optional public build-time vars (Astro `PUBLIC_*` are inlined into the client bundle).

# Override GTM container (default in code: GTM-KXJGBL5W from legacy WP; see docs/existing-site-structure.md).
# PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXXX

# CookieYes client id from the dashboard (enables https://cdn-cookieyes.com/client_data/.../script.js).
# PUBLIC_COOKIEYES_CLIENT_ID=
